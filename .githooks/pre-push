#!/bin/sh
#
# pre-push hook — two independent guards:
#
#   1. Release-tag gate. Any ref pushed under refs/tags/v* is handed to
#      `./sb release verify-tag`, which rejects hand-rolled tags that
#      skip the signature / next-in-sequence / immutability checks that
#      `./sb release prerelease` and `./sb release stable` enforce.
#      Lightweight tags are rejected unconditionally (release tags must
#      be annotated).
#
#   2. Dockerfile pgrx-builder gate. If any commit being pushed modifies
#      postgres/Dockerfile, build the three pgrx-builder stages locally
#      and fail the push on any build error. Introduced after commit
#      13fc8a7f7 broke ci-images with a regression a single local
#      `docker build` would have caught in seconds.
#
# Bypass (e.g. when you've just validated by hand):
#   git push --no-verify
#
# Activation (once, per clone):
#   git config core.hooksPath .githooks
#
# Cost when the Dockerfile gate triggers:
#   First run from cold: ~10-15 minutes (clones + cargo pgrx init +
#   three Rust builds). Subsequent runs reuse build cache, typically
#   <2 minutes unless the extension versions advance.

set -eu

remote="$1"
# url="$2"   # unused; pushing to any remote triggers the same check

# Both guards want to walk the list of refs/SHAs being pushed. stdin can
# be read only once, so buffer it into a temp file and feed each loop
# from the file.
hook_input=$(mktemp)
trap 'rm -f "$hook_input"' EXIT
cat > "$hook_input"

zero='0000000000000000000000000000000000000000'
root=$(git rev-parse --show-toplevel)

# --- Guard 1: release-tag gate ---------------------------------------
# For every ref being pushed that lives under refs/tags/v*, validate it
# with ./sb release verify-tag. Lightweight tags are rejected before the
# subcommand even runs (verify-tag also rejects them, but this branch
# gives a clearer error and is free).
#
# Bypass compatibility: if the local sb binary is older than the one
# that introduced verify-tag, we skip with a warning rather than block
# all tag pushes. The subcommand is considered present when
# `./sb release verify-tag --help` exits 0.
sb_verify_tag_available=0
if [ -x "$root/sb" ] && "$root/sb" release verify-tag --help >/dev/null 2>&1; then
    sb_verify_tag_available=1
fi

while read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "${local_ref:-}" ] && continue
    [ "$local_sha" = "$zero" ] && continue   # skip deletions
    case "$remote_ref" in
        refs/tags/v*)
            tag_name="${remote_ref#refs/tags/}"
            tag_type=$(git cat-file -t "$local_sha" 2>/dev/null || echo 'missing')
            if [ "$tag_type" != "tag" ]; then
                cat >&2 <<MSG

pre-push: $tag_name is a lightweight tag — release tags must be annotated.
pre-push: Create via './sb release prerelease' or './sb release stable',
pre-push: not 'git tag' by hand. Bypass (discouraged): git push --no-verify

MSG
                exit 1
            fi
            if [ "$sb_verify_tag_available" -eq 0 ]; then
                cat >&2 <<MSG
pre-push: ./sb release verify-tag not available in this binary.
pre-push: Rebuild: (cd cli && go build -o ../sb .)
pre-push: Skipping tag validation for $tag_name; CI will still catch bad tags.
MSG
                continue
            fi
            if ! "$root/sb" release verify-tag "$tag_name" >&2; then
                cat >&2 <<MSG

pre-push: tag $tag_name failed pre-creation validation.
pre-push: Create via './sb release prerelease' or './sb release stable',
pre-push: not 'git tag' by hand. Bypass (discouraged): git push --no-verify

MSG
                exit 1
            fi
            ;;
    esac
done < "$hook_input"

# --- Guard 2: Dockerfile pgrx-builder gate ---------------------------
# Gather the list of local SHAs being pushed. stdin lines look like:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
# A zero sha means branch deletion or an empty remote.
shas=''
while read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "${local_ref:-}" ] && continue
    [ "$local_sha" = "$zero" ] && continue   # skip deletions
    if [ "$remote_sha" = "$zero" ]; then
        # New branch — diff against the merge-base with the default head
        range="$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi
    shas="$shas $range"
done < "$hook_input"

# Nothing being pushed (e.g. --delete of nonexistent) — pass.
[ -z "$shas" ] && exit 0

# Does any commit in any pushed range touch postgres/Dockerfile?
touched=$(git log --name-only --pretty=format: $shas 2>/dev/null | \
    grep -xF 'postgres/Dockerfile' | head -1 || true)

if [ -z "$touched" ]; then
    exit 0
fi

cat >&2 <<'MSG'

pre-push: postgres/Dockerfile is modified in commits being pushed.
pre-push: Validating all three pgrx-builder stages locally before allowing push.
pre-push: (pass --no-verify to skip; CI will still catch failures on master.)

MSG

# Need a working docker daemon. If it's not available, warn and bail
# (we don't want to block pushes on a dev laptop where docker is off).
if ! docker info >/dev/null 2>&1; then
    cat >&2 <<'MSG'
pre-push: docker is not running on this machine. Skipping the build
pre-push: check. CI on master WILL catch any Dockerfile regression.
MSG
    exit 0
fi

cd "$root/postgres"

for stage in pg_graphql-builder jsonb_stats-builder sql_saga_native-builder; do
    echo "pre-push: docker build --target=$stage ..." >&2
    if ! docker build -f Dockerfile --target="$stage" -q . >/dev/null; then
        cat >&2 <<MSG

pre-push: FAILED — '$stage' did not build cleanly. Fix the Dockerfile
pre-push: and try again. Run manually to iterate:
pre-push:
pre-push:   docker build -f postgres/Dockerfile --target=$stage ./postgres
pre-push:
pre-push: Bypass (only if you know what you're doing):
pre-push:   git push --no-verify
MSG
        exit 1
    fi
done

echo "pre-push: all three pgrx-builder stages built cleanly." >&2
exit 0
