#!/bin/sh
#
# pre-push hook — two independent guards on release-tag pushes:
#
#   1. Release-tag gate. Any ref pushed under refs/tags/v* is handed to
#      `./sb release verify-tag`, which rejects hand-rolled tags that
#      skip the signature / next-in-sequence / immutability checks that
#      `./sb release prerelease` and `./sb release stable` enforce.
#      Lightweight tags are rejected unconditionally (release tags must
#      be annotated).
#
#   2. CI Images gate. Any release tag push must point at a commit for
#      which ci-images.yaml on GitHub Actions has completed successfully.
#      `./sb release verify-ci <commit>` asks the GitHub API — the guard
#      is fast (no local docker builds, no rustup), blocks the push on a
#      missing / pending / failed run, and prints the exact
#      `gh workflow run` command an operator needs to repair the gap.
#      Replaces an older slow local replay of the same Docker builds
#      that duplicated CI's work and only failed at push time after the
#      tag had already been created.
#
# Bypass (e.g. validated by hand, or GitHub is down):
#   git push --no-verify
#
# Activation (once, per clone):
#   git config core.hooksPath .githooks

set -eu

remote="$1"
# url="$2"   # unused; pushing to any remote triggers the same checks

# Both guards walk the same list of refs/SHAs. stdin can be read only
# once, so buffer it into a temp file and feed each loop from the file.
hook_input=$(mktemp)
trap 'rm -f "$hook_input"' EXIT
cat > "$hook_input"

zero='0000000000000000000000000000000000000000'
root=$(git rev-parse --show-toplevel)

# --- Guard 1: release-tag gate ---------------------------------------
# For every ref being pushed that lives under refs/tags/v*, validate it
# with ./sb release verify-tag. Lightweight tags are rejected before the
# subcommand even runs (verify-tag also rejects them, but this branch
# gives a clearer error and is free).
#
# Bypass compatibility: if the local sb binary is older than the one
# that introduced verify-tag, we skip with a warning rather than block
# all tag pushes. The subcommand is considered present when
# `./sb release verify-tag --help` exits 0.
sb_verify_tag_available=0
if [ -x "$root/sb" ] && "$root/sb" release verify-tag --help >/dev/null 2>&1; then
    sb_verify_tag_available=1
fi

while read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "${local_ref:-}" ] && continue
    [ "$local_sha" = "$zero" ] && continue   # skip deletions
    case "$remote_ref" in
        refs/tags/v*)
            tag_name="${remote_ref#refs/tags/}"
            tag_type=$(git cat-file -t "$local_sha" 2>/dev/null || echo 'missing')
            if [ "$tag_type" != "tag" ]; then
                cat >&2 <<MSG

pre-push: $tag_name is a lightweight tag — release tags must be annotated.
pre-push: Create via './sb release prerelease' or './sb release stable',
pre-push: not 'git tag' by hand. Bypass (discouraged): git push --no-verify

MSG
                exit 1
            fi
            if [ "$sb_verify_tag_available" -eq 0 ]; then
                cat >&2 <<MSG
pre-push: ./sb release verify-tag not available in this binary.
pre-push: Rebuild: (cd cli && go build -o ../sb .)
pre-push: Skipping tag validation for $tag_name; CI will still catch bad tags.
MSG
                continue
            fi
            if ! "$root/sb" release verify-tag "$tag_name" >&2; then
                cat >&2 <<MSG

pre-push: tag $tag_name failed pre-creation validation.
pre-push: Create via './sb release prerelease' or './sb release stable',
pre-push: not 'git tag' by hand. Bypass (discouraged): git push --no-verify

MSG
                exit 1
            fi
            ;;
    esac
done < "$hook_input"

# --- Guard 2: CI Images gate -----------------------------------------
# Any release tag push must point at a commit for which ci-images.yaml
# has completed successfully on GitHub Actions. Replaces the older
# slow local replay of the three pgrx-builder Docker stages, which
# duplicated CI's work and hung for minutes on cold caches. The fast
# guard here just asks GitHub what its own CI verdict is. If the tag's
# commit hasn't been validated yet, the operator gets the exact
# `gh workflow run` command to fix it.
#
# Backward compat: if `./sb release verify-ci` isn't present (sb
# predates v3), skip with a warning. CI on master will still catch
# artifacts regressions.
sb_verify_ci_available=0
if [ -x "$root/sb" ] && "$root/sb" release verify-ci --help >/dev/null 2>&1; then
    sb_verify_ci_available=1
fi

while read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "${local_ref:-}" ] && continue
    [ "$local_sha" = "$zero" ] && continue   # skip deletions
    case "$remote_ref" in
        refs/tags/v*)
            tag_name="${remote_ref#refs/tags/}"
            if [ "$sb_verify_ci_available" -eq 0 ]; then
                cat >&2 <<MSG
pre-push: ./sb release verify-ci not available in this binary.
pre-push: Rebuild: (cd cli && go build -o ../sb .)
pre-push: Skipping CI Images gate for $tag_name; CI on master will catch regressions.
MSG
                continue
            fi
            # Annotated tags: local_sha is the tag object; rev-list -1
            # dereferences to the target commit. Guard 1 already
            # rejected lightweight tags above, so we know we have an
            # annotated one.
            target_commit=$(git rev-list -1 "$local_sha" 2>/dev/null || echo '')
            if [ -z "$target_commit" ]; then
                cat >&2 <<MSG

pre-push: could not resolve $tag_name to a target commit for CI Images check.
pre-push: Bypass (discouraged): git push --no-verify

MSG
                exit 1
            fi
            if ! "$root/sb" release verify-ci "$target_commit" >&2; then
                cat >&2 <<MSG

pre-push: $tag_name failed the CI Images gate (see message above).
pre-push: This guard is fast — no local docker builds, no rustup.
pre-push: Follow the printed Fix / Trigger guidance and retry the push.

MSG
                exit 1
            fi
            ;;
    esac
done < "$hook_input"

exit 0
