#!/bin/sh
#
# This pre-commit hook:
# 1. Prevents committing files from 'tmp/' and 'app/tmp/' directories
# 2. Auto-regenerates PlantUML SVGs when .plantuml files are staged
# 3. Requires migration commits to be paired with doc/db/ regeneration

# =============================================================================
# Check for staged files in tmp/ directories
# =============================================================================
# This allows these directories to be used as a scratch space for AI tools without
# polluting the main commit history. Files in them can still be tracked
# locally with `git add` to see diffs. An exception is made for `.gitkeep` and
# `.gitignore` files.

STAGED_TMP_FILES=$(git diff --cached --name-only --diff-filter=d | grep -E '^(tmp|app/tmp)/' | grep -v -E '/\.(gitkeep|gitignore)$')

if [ -n "$STAGED_TMP_FILES" ]; then
    echo "COMMIT REJECTED"
    echo "-----------------"
    echo "Error: Committing files from the 'tmp/' or 'app/tmp/' directories is not allowed."
    echo
    echo "These directories are for local scratch work and AI tool interaction."
    echo "To commit changes from files in these directories, please move them to an appropriate location."
    echo
    echo "The following staged files must be unstaged:"
    # List the problematic files
    echo "$STAGED_TMP_FILES"
    echo
    exit 1
fi

# =============================================================================
# Auto-regenerate PlantUML SVGs when .plantuml files change
# =============================================================================
# Requires: brew install plantuml (or Docker alternative)

STAGED_PLANTUML=$(git diff --cached --name-only | grep '\.plantuml$')

if [ -n "$STAGED_PLANTUML" ]; then
    # Check if plantuml is available
    if command -v plantuml >/dev/null 2>&1; then
        echo "Regenerating PlantUML diagrams..."
        
        # Generate SVGs for each changed .plantuml file
        for puml in $STAGED_PLANTUML; do
            if [ -f "$puml" ]; then
                plantuml -tsvg "$puml"
                svg_file="${puml%.plantuml}.svg"
                if [ -f "$svg_file" ]; then
                    git add "$svg_file"
                    echo "  Updated: $svg_file"
                fi
            fi
        done
    else
        echo "WARNING: PlantUML not installed. SVG files may be out of date."
        echo "Install with: brew install plantuml"
        echo "Or generate manually: plantuml -tsvg doc/diagrams/*.plantuml"
    fi
fi

# =============================================================================
# Require doc/db/ regen alongside migrations
# =============================================================================
# Migrations that change function / view / procedure / table definitions are
# illegible at the SQL-text level (you see a CREATE OR REPLACE FUNCTION blob,
# not the actual logic delta). doc/db/ is the canonical "current schema state"
# reference — regenerated via `./dev.sh generate-doc-db`. Pairing
# migrations with their doc/db/ regen in the same commit gives reviewers a
# clean per-object diff alongside the migration text.
#
# RULE: if any staged file is under migrations/, at least one staged file must
# be under doc/db/ as well. Broad heuristic — doesn't try to match individual
# objects to specific files (that requires SQL parsing and is fragile).
#
# OVERRIDE (rare): git commit --no-verify
# For migrations that genuinely have no schema-doc impact (e.g. a pure
# data-only migration with no schema changes). Should be uncommon.

STAGED_MIGRATIONS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^migrations/.*\.sql$' || true)

if [ -n "$STAGED_MIGRATIONS" ]; then
    STAGED_DOCDB=$(git diff --cached --name-only --diff-filter=ACMD | grep -E '^doc/db/' || true)
    if [ -z "$STAGED_DOCDB" ]; then
        echo "COMMIT REJECTED"
        echo "-----------------"
        echo "Error: Migration commit lacks paired doc/db/ regeneration."
        echo
        echo "Staged migrations:"
        echo "$STAGED_MIGRATIONS" | sed 's/^/  /'
        echo
        echo "WHY: migrations changing function/view/procedure/table definitions are"
        echo "illegible at the SQL-text level (CREATE OR REPLACE FUNCTION blobs hide"
        echo "the actual logic delta). doc/db/ provides a clean per-object diff for"
        echo "reviewers. Pairing the regen in the same commit makes the change"
        echo "reviewable."
        echo
        echo "HOW TO FIX (schema migrations — the common case):"
        echo "  1. Bring the seed to HEAD so the regen reflects your migration (non-destructive —"
        echo "     applies the migration to the seed DB; NOT recreate-database):"
        echo "       ./sb migrate up --target seed   &&   ./dev.sh create-test-template"
        echo "  2. Regenerate from the current schema. This WORKS even with the migration"
        echo "     uncommitted — the freshness stamp is simply deferred until the tree is clean:"
        echo "       ./dev.sh generate-doc-db   &&   ./sb types generate"
        echo "  3. Stage the regen alongside your migration:"
        echo "       git add doc/db/ app/src/lib/database.types.ts"
        echo "  4. Commit again — migration + regen go together; this hook then passes (no override)."
        echo
        echo "OVERRIDE — ONLY for a DATA-ONLY migration with NO schema impact (a backfill/UPDATE"
        echo "that changes no table/view/function/procedure definition, so doc/db/ genuinely would"
        echo "not change). Do NOT use it for a schema migration — pair the regen as above instead:"
        echo "  git commit --no-verify"
        echo
        echo "Hook source: .githooks/pre-commit"
        exit 1
    fi
fi

# =============================================================================
# Block blessing a failing security report
# =============================================================================
# doc/db-security-report.md is generated by test 008's security checks. A
# non-exempt public table missing RLS, or a view missing required grants, renders
# as a ⚠️ marker in the report. Committing it with a ⚠️ present blesses a
# known-broken security state into the baseline — the laundering anti-pattern that
# once hid an unregistered SECURITY DEFINER function for months.
#
# No override: a ⚠️ in the security report is never correct to commit. Fix the
# underlying gap (add the RLS policy / grant, or register the exemption with
# justification in test/sql/008_verify_rls_and_grants.sql), regenerate, and commit
# the clean report.

STAGED_SECURITY_REPORT=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^doc/db-security-report\.md$' || true)
if [ -n "$STAGED_SECURITY_REPORT" ]; then
    # Inspect the STAGED content (what's about to be committed), not the worktree.
    if git show ":doc/db-security-report.md" | grep -q '⚠️'; then
        echo "COMMIT REJECTED"
        echo "-----------------"
        echo "Error: doc/db-security-report.md contains a ⚠️ failure marker."
        echo
        echo "That marker means a non-exempt public table is missing RLS, or a view"
        echo "is missing required grants — a real security gap. Committing the report"
        echo "with it blesses a broken state into the baseline (laundering)."
        echo
        echo "Fix the underlying gap (add the RLS policy / grant, or register the"
        echo "exemption with justification in test/sql/008_verify_rls_and_grants.sql),"
        echo "regenerate the report, then commit the clean version."
        echo
        echo "Hook source: .githooks/pre-commit"
        exit 1
    fi
fi

exit 0
