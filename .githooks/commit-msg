#!/bin/bash
# commit-msg hook — reject ALL bare hash-digit ticket references in commit
# messages.
#
# Ticket numbers are ephemeral across time, regardless of their origin:
#  - Session-scoped TaskCreate IDs get purged when the session ends.
#  - GitHub issue/PR shorthand collides across forks and breaks on repo rename.
#  - Internal tracker numbers depend on a system the future reader may not have.
#
# The PERMANENT reference is the full URL. If you want to point at an issue
# or PR, paste the URL — that survives.
#
# Detection:
#   Step 1: strip URLs from the message (URLs may legitimately contain "#").
#   Step 2: look for any remaining "#<digits>" pattern.
#
# Matches: closes 1234, fix 42, refs 7, see 100, Task 94, task-42
#   (each in their bare hash-prefixed form — examples here use space to avoid
#   self-tripping)
# Non-matches (safe shell/code constructs):
#   #define, #!/bin/bash, #hashtag, https://example.com/issues/100
#
# Override: git commit --no-verify

set -euo pipefail

COMMIT_MSG_FILE="$1"
MSG="$(cat "$COMMIT_MSG_FILE")"

# Strip comment lines — lines starting with "#" followed by NON-digit
# (real git comments like "# Please enter the commit message"). KEEP lines
# starting with "#<digit>" because those are ticket references at line start
# that the operator may have written via `git commit -m` (which doesn't
# strip comments) and which we DO want to flag.
STRIPPED=$(echo "$MSG" | grep -vE '^[[:space:]]*#([^0-9]|$)' || true)

# Strip URLs (may legitimately contain "#" for path/fragment). Match http(s)://
# git:// or ssh:// up to whitespace, close-paren, or close-quote.
NO_URL=$(echo "$STRIPPED" | sed -E 's@(https?|git|ssh)://[^[:space:])"'"'"']+@@g')

# Search for any "#" immediately followed by digits in the URL-stripped text.
# Match anywhere (including mid-word like "claude-code#25135") because such
# shorthand is exactly the unreliable form we want to flag.
# Safe: "#define" (no digit after "#"), "#!/bin/bash" (shebang), "#hashtag".
MATCHES=$(echo "$NO_URL" | grep -inE '#[0-9]+' || true)

if [[ -n "$MATCHES" ]]; then
  MATCHED_LINES=$(echo "$MATCHES" | sed 's/^/  /')
  cat >&2 <<EOF
COMMIT-MSG BLOCKED: your commit message contains a bare ticket reference
(hash followed by digits).

WHY: Ticket numbers are ephemeral across time. Whether the source is
session-scoped (TaskCreate IDs), GitHub issue, or PR shorthand, the BARE
hash-prefixed number is unreliable: task lists get purged, fork repos
collide on numbering, repos get renamed/transferred. Six months from now,
a bare hash-number is a dead pointer.

The PERMANENT reference is the full URL. If you want to point at an
issue or PR, paste its URL.

Matched lines:
${MATCHED_LINES}

HOW TO FIX:
- Describe the change so the message stands alone — what and why, no
  ticket shorthand.
- If you need to reference an issue or PR, include the full URL, e.g.:
    https://github.com/statisticsnorway/statbus/issues/100
  rather than:
    closes #100

OVERRIDE (strongly discouraged — this rule exists because we've already
polluted history with dead ticket references):
  git commit --no-verify

Hook source: .githooks/commit-msg
EOF
  exit 1
fi

# ── Check 2: justify new ERROR/FATAL/PANIC lines in staged expected files ──
#
# When a commit touches test/expected/*.out and the diff adds ERROR /
# FATAL / PANIC lines, require the commit message body to contain a
# justification line per new error:
#
#   expected-error: <file>:<lineno> [— <reason>]
#
# WHY: the COMMITTING AGENT owns the durable record of why each
# expected error is acceptable. The test-SQL marker (SAVEPOINT,
# ON_ERROR_STOP, EXCEPTION block, "-- expected to fail" comment)
# proves intent at the test-author level. This commit-msg
# justification proves intent at the COMMIT level — different actor,
# different moment, different judgment. Both required = belt +
# suspenders against silent baseline-of-bugs.
#
# Cascade errors ("current transaction is aborted") are skipped —
# they're consequences of an earlier ERROR, not new failures.
#
# Override: git commit --no-verify

STAGED_EXPECTED=$(git diff --cached --name-only --diff-filter=AM 2>/dev/null \
  | grep -E '^test/expected/.*\.out$' || true)

if [[ -n "$STAGED_EXPECTED" ]]; then
  MISSING=""
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue

    # New ERROR/FATAL/PANIC line numbers in the staged version of $file.
    NEW_LINENUMS=$(git diff --cached -U0 -- "$file" 2>/dev/null | awk '
      /^@@/ {
        for (i = 1; i <= NF; i++) {
          if ($i ~ /^\+/) {
            sub(/^\+/, "", $i)
            split($i, a, ",")
            new_line = a[1] - 1
            break
          }
        }
        next
      }
      /^---/ || /^\+\+\+/ { next }
      /^\+/ {
        new_line++
        if (/^\+(ERROR|FATAL|PANIC):/) print new_line
        next
      }
      /^-/ { next }
      { new_line++ }
    ' || true)

    while IFS= read -r lineno; do
      [[ -z "$lineno" ]] && continue
      line_text=$(git show ":0:$file" 2>/dev/null | sed -n "${lineno}p")
      if echo "$line_text" | grep -q "current transaction is aborted"; then
        continue
      fi
      # Require: a commit-msg line of the form `expected-error: <file>:<lineno>`
      if ! echo "$STRIPPED" | grep -qE "^[[:space:]]*expected-error:[[:space:]]+${file}:${lineno}([^0-9]|$)"; then
        MISSING="${MISSING}  ${file}:${lineno}: ${line_text}"$'\n'
      fi
    done <<< "$NEW_LINENUMS"
  done <<< "$STAGED_EXPECTED"

  if [[ -n "$MISSING" ]]; then
    cat >&2 <<EOF
COMMIT-MSG BLOCKED: new ERROR/FATAL/PANIC lines in staged
test/expected/*.out files require per-line justification.

Unjustified new error(s):
${MISSING}
WHY: the committing agent must record WHY each expected error is
acceptable at the moment of commit, in the durable record. Test-SQL
markers (SAVEPOINT / ON_ERROR_STOP / EXCEPTION / "expected to fail"
comments) prove the test author's intent; this commit-msg justification
proves the committing agent's deliberate acceptance.

HOW TO FIX:
Add one or more lines to your commit message body, one per new error:

  expected-error: <file>:<lineno> — <reason>

Example:
  expected-error: test/expected/318_facet_drift_self_healing.out:315 — dup-key bug-capture pre-fix; test intentionally fails until the schema-extension migration lands.

The hook matches lines starting with "expected-error:" followed by the
exact file path + ":" + the new line number in the staged file.

OVERRIDE (strongly discouraged):
  git commit --no-verify

Hook source: .githooks/commit-msg
EOF
    exit 1
  fi
fi

# ── Check 3 (2026-05-24): justify new WARNING lines in staged expected files ──
#
# Mirrors Check 2 above, but for WARNING severity.  When a commit touches
# test/expected/*.out and the diff adds WARNING lines, the commit message
# must contain a per-line justification:
#
#   expected-warning: <file>:<lineno> [— <reason>]
#
# WHY: On 2026-05-24 King's code review caught a semantic regression in
# commit 5bcb523ef (later 0fa05f406): 22001 WARNING stack traces were added
# to test/expected/347_*.out and the engineer labelled them "mechanical
# drift" — they were the Albania process_location value-too-long bug
# returning (SQLSTATE 22001).  Had this check been in place the commit
# would have been blocked, forcing deliberate acceptance or investigation
# before the regression landed.
#
# Cascade WARNINGs ("current transaction is aborted") are skipped — same
# cascade-suppression rule as Check 2's ERROR handling.
#
# Override: git commit --no-verify

if [[ -n "$STAGED_EXPECTED" ]]; then
  MISSING_WARNINGS=""
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue

    # New WARNING line numbers in the staged version of $file.
    NEW_WARNING_LINENUMS=$(git diff --cached -U0 -- "$file" 2>/dev/null | awk '
      /^@@/ {
        for (i = 1; i <= NF; i++) {
          if ($i ~ /^\+/) {
            sub(/^\+/, "", $i)
            split($i, a, ",")
            new_line = a[1] - 1
            break
          }
        }
        next
      }
      /^---/ || /^\+\+\+/ { next }
      /^\+/ {
        new_line++
        if (/^\+WARNING:/) print new_line
        next
      }
      /^-/ { next }
      { new_line++ }
    ' || true)

    while IFS= read -r lineno; do
      [[ -z "$lineno" ]] && continue
      line_text=$(git show ":0:$file" 2>/dev/null | sed -n "${lineno}p")
      # Skip cascade WARNINGs that are consequences of an earlier ERROR.
      if echo "$line_text" | grep -q "current transaction is aborted"; then
        continue
      fi
      # Require: a commit-msg line of the form `expected-warning: <file>:<lineno>`
      if ! echo "$STRIPPED" | grep -qE "^[[:space:]]*expected-warning:[[:space:]]+${file}:${lineno}([^0-9]|$)"; then
        MISSING_WARNINGS="${MISSING_WARNINGS}  ${file}:${lineno}: ${line_text}"$'\n'
      fi
    done <<< "$NEW_WARNING_LINENUMS"
  done <<< "$STAGED_EXPECTED"

  if [[ -n "$MISSING_WARNINGS" ]]; then
    cat >&2 <<EOF
COMMIT-MSG BLOCKED: new WARNING lines in staged
test/expected/*.out files require per-line justification.

Unjustified new warning(s):
${MISSING_WARNINGS}
WHY: the committing agent must record WHY each expected warning is
acceptable at the moment of commit, in the durable record.  On
2026-05-24 King's code review caught a semantic regression where new
WARNING lines in test/expected/347_*.out were baselined as "mechanical
drift" — they were the Albania process_location value-too-long bug
(SQLSTATE 22001) returning.  Explicit acceptance prevents silent
regression of this class.

HOW TO FIX:
Add one or more lines to your commit message body, one per new warning:

  expected-warning: <file>:<lineno> — <reason>

Example:
  expected-warning: test/expected/347_import_field_length_limits.out:42 — deliberate truncation warning from analyse_length_limits; test verifies truncate+warn path.

The hook matches lines starting with "expected-warning:" followed by the
exact file path + ":" + the new line number in the staged file.

OVERRIDE (strongly discouraged):
  git commit --no-verify

Hook source: .githooks/commit-msg
EOF
    exit 1
  fi
fi

exit 0
