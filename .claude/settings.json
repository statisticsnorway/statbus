{
  "worktree": {
    "bgIsolation": "none"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/require-bash-background.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/restrict-agent-spawn.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/no-migration-archaeology.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/doc-db-freshness.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/ban-force-add.sh", "timeout": 5, "_deactivated": "enable with HOOK_ENABLED_BAN_FORCE_ADD=1" },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/require-git-c.sh", "timeout": 5, "_deactivated": "enable with HOOK_ENABLED_REQUIRE_GIT_C=1" },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/migration-cluster-statement-gate.sh", "timeout": 10 }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/restrict-agent-spawn.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/enforce-team-name.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "TeamCreate",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/enforce-team-name.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/route-alias.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/remind-report-via-sendmessage.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "TaskCreate",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/require-backlog-tasks.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "mcp__backlog__task_create",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/require-backlog-slug.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "mcp__backlog__task_edit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/require-backlog-slug.sh", "timeout": 5 }
        ]
      }
    ]
  }
}
