-- ═════════════════════════════════════════════════════════════════════════
-- ─── C7: Strict mode, at-limit value (no error) ──────────────────────────
SAVEPOINT scenario_c7;
\echo

\echo "=== C7 [truncate=false, DEFAULT]: At-limit value (200-char address) ==="
"=== C7 [truncate=false, DEFAULT]: At-limit value (200-char address) ==="
