-- ─── C12: Strict mode, mixed-batch survival — 3 good + 1 overlong row ───
SAVEPOINT scenario_c12;
\echo

\echo "=== C12 [truncate=false, DEFAULT]: Mixed batch — 3 good rows + 1 overlong row ==="
"=== C12 [truncate=false, DEFAULT]: Mixed batch — 3 good rows + 1 overlong row ==="
\echo "This is THE headline case from the original deep bug: pre-fix, ONE bad row in a"
"This is THE headline case from the original deep bug: pre-fix, ONE bad row in a"
\echo "batch raised 22001 at process_location MERGE and aborted the entire job with"
"batch raised 22001 at process_location MERGE and aborted the entire job with"
\echo "import_job.state='failed' — the operator lost ALL rows including the good ones,"
"import_job.state='failed' — the operator lost ALL rows including the good ones,"
\echo "with no recovery path beyond reading raw logs."
"with no recovery path beyond reading raw logs."
\echo

\echo "Post-fix with strict default: the bad row is marked state='error' cleanly in"
"Post-fix with strict default: the bad row is marked state='error' cleanly in"
\echo "_data; the good rows are also intact in _data (state IS DISTINCT FROM 'error');"
"_data; the good rows are also intact in _data (state IS DISTINCT FROM 'error');"
\echo "the job halts at state='waiting_for_review' rather than running the process step"
"the job halts at state='waiting_for_review' rather than running the process step"
\echo "automatically. The operator reviews the error row (fix source data, or mark"
"automatically. The operator reviews the error row (fix source data, or mark"
\echo "skip), then runs the next stage. Critically: NO catastrophic job failure;"
"skip), then runs the next stage. Critically: NO catastrophic job failure;"
\echo "good rows are recoverable; bad rows are diagnosable."
"good rows are recoverable; bad rows are diagnosable."
\echo

\echo "Expectations:"
"Expectations:"
\echo "  - _data: 3 non-error + 1 error row"
"  - _data: 3 non-error + 1 error row"
\echo "  - bad row's errors JSONB has physical_address_part1 too_long entry"
"  - bad row's errors JSONB has physical_address_part1 too_long entry"
\echo "  - job.state IS DISTINCT FROM 'failed' (the catastrophic pre-fix state)"
"  - job.state IS DISTINCT FROM 'failed' (the catastrophic pre-fix state)"
\echo "  - import_job.error IS NULL (no top-level job-killing error)"
"  - import_job.error IS NULL (no top-level job-killing error)"
DO $$
DECLARE
    v_definition_id INT;
BEGIN
    SELECT id INTO v_definition_id FROM public.import_definition WHERE slug = 'legal_unit_source_dates';
    INSERT INTO public.import_job (definition_id, slug, description, note, edit_comment)
    VALUES (v_definition_id, 'imp_347_c12_mixed', 'Test 347 C12 mixed batch survival', '3 good + 1 overlong', 'Test 347');
END $$;
INSERT INTO public.imp_347_c12_mixed_upload(
    valid_from, valid_to, tax_ident, name, birth_date, physical_address_part1,
    physical_country_iso_2, primary_activity_category_code, sector_code, legal_form_code
) VALUES
    -- 3 good rows
    ('2020-01-01', '2020-12-31', '347001201', 'C12 Good One',   '2020-01-01', 'Good Street 1',  'NO', '01.110', '2100', 'AS'),
    ('2020-01-01', '2020-12-31', '347001202', 'C12 Good Two',   '2020-01-01', 'Good Street 2',  'NO', '01.110', '2100', 'AS'),
    ('2020-01-01', '2020-12-31', '347001203', 'C12 Good Three', '2020-01-01', 'Good Street 3',  'NO', '01.110', '2100', 'AS'),
    -- 1 bad row (250-char address > varchar(200))
    ('2020-01-01', '2020-12-31', '347001204', 'C12 Bad Overlong', '2020-01-01', repeat('Z', 250), 'NO', '01.110', '2100', 'AS');
CALL worker.process_tasks(p_queue => 'import');
\echo "C12 _data row counts by state (expect 3 non-error + 1 error):"
"C12 _data row counts by state (expect 3 non-error + 1 error):"
SELECT
    count(*) FILTER (WHERE state IS DISTINCT FROM 'error') AS non_error_rows,
    count(*) FILTER (WHERE state = 'error') AS error_rows
FROM public.imp_347_c12_mixed_data;
 non_error_rows | error_rows 
----------------+------------
              3 |          1
(1 row)

\echo "C12 error row has physical_address_part1 in errors:"
"C12 error row has physical_address_part1 in errors:"
SELECT row_id,
       errors ? 'physical_address_part1' AS has_addr_err,
       errors #>> '{physical_address_part1,too_long}' AS too_long
FROM public.imp_347_c12_mixed_data
WHERE state = 'error'
ORDER BY row_id;
 row_id | has_addr_err | too_long 
--------+--------------+----------
      4 | t            | 250
(1 row)

\echo "C12 job state (must NOT be 'failed' — the catastrophic pre-fix state):"
"C12 job state (must NOT be 'failed' — the catastrophic pre-fix state):"
\echo "Acceptable post-fix states are 'waiting_for_review' (operator must triage error"
"Acceptable post-fix states are 'waiting_for_review' (operator must triage error"
\echo "row before commit) or 'finished' (depending on definition's review gates). Both"
"row before commit) or 'finished' (depending on definition's review gates). Both"
\echo "are correct outcomes of the strict-default policy. The CRITICAL contract is"
"are correct outcomes of the strict-default policy. The CRITICAL contract is"
\echo "state != 'failed' — i.e. the 22001 batch-killer no longer fires."
"state != 'failed' — i.e. the 22001 batch-killer no longer fires."
SELECT slug,
       state,
       state = 'failed' AS catastrophic_failure,
       error IS NOT NULL AS job_has_top_level_error
FROM public.import_job WHERE slug = 'imp_347_c12_mixed';
       slug        |       state        | catastrophic_failure | job_has_top_level_error 
-------------------+--------------------+----------------------+-------------------------
 imp_347_c12_mixed | waiting_for_review | f                    | f
