BEGIN;
\i test/setup.sql
\echo -- test/setup.sql output suppressed for cleaner test output
-- test/setup.sql output suppressed for cleaner test output
\set ECHO none
\echo -- test/setup.sql done, test output follows
-- test/setup.sql done, test output follows
\echo "=== Power Group Worker Derivation Test ==="
"=== Power Group Worker Derivation Test ==="
\echo "Testing automated derivation of power groups from parent_company relationships"
"Testing automated derivation of power groups from parent_company relationships"
-- Reset the power_group sequence to ensure consistent test results
ALTER SEQUENCE public.power_group_ident_seq RESTART WITH 1;
-- A Super User configures statbus.
CALL test.set_user_from_email('test.admin@statbus.org');
-- Load base configuration (regions, activity categories, status codes, etc.)
\i samples/norway/getting-started.sql
\i samples/norway/settings.sql
INSERT INTO settings(activity_category_standard_id,country_id)
SELECT (SELECT id FROM activity_category_standard WHERE code = 'nace_v2.1')
     , (SELECT id FROM public.country WHERE iso_2 = 'NO')
ON CONFLICT (only_one_setting)
DO UPDATE SET
   activity_category_standard_id = EXCLUDED.activity_category_standard_id,
   country_id = EXCLUDED.country_id
   WHERE settings.only_one_setting = EXCLUDED.only_one_setting;
;
\i samples/norway/activity_category/activity_category_norway.sql
\copy public.activity_category_available_custom FROM 'samples/norway/activity_category/activity_category_norway.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
\i samples/norway/regions/norway-regions-2024.sql
\copy public.region_upload(path, name) FROM 'samples/norway/regions/norway-regions-2024.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
\i samples/norway/sector/sector_norway.sql
\copy public.sector_custom_only FROM 'samples/norway/sector/sector_norway.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
\i samples/norway/legal_form/legal_form_norway.sql
\copy public.legal_form_custom_only FROM 'samples/norway/legal_form/legal_form_norway.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
\i samples/norway/data_source/data_source_norway.sql
\copy public.data_source_custom (code, name) FROM 'samples/norway/data_source/data_source_norway.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
-- Seed test relationship types
-- parent_company: structurally 1:1 (a subsidiary has at most one parent) → TRUE
-- co_ownership: structurally 1:N (multiple co-owners per entity) → FALSE
INSERT INTO public.legal_rel_type (code, name, description, primary_influencer_only, enabled, custom)
SELECT 'parent_company', 'Parent Company', 'Parent-subsidiary relationship (structurally 1:1 per subsidiary)', TRUE, true, false
WHERE NOT EXISTS (SELECT 1 FROM public.legal_rel_type WHERE code = 'parent_company');
INSERT INTO public.legal_rel_type (code, name, description, primary_influencer_only, enabled, custom)
SELECT 'co_ownership', 'Co-ownership', 'Shared ownership (multiple co-owners per entity)', FALSE, true, false
WHERE NOT EXISTS (SELECT 1 FROM public.legal_rel_type WHERE code = 'co_ownership');
-- ============================================================================
\echo "=== Section 1: Verify Worker Infrastructure ==="
"=== Section 1: Verify Worker Infrastructure ==="
-- ============================================================================
\echo "Check views exist"
"Check views exist"
SELECT table_schema, table_name, table_type
FROM information_schema.tables
WHERE table_name IN ('power_group_def', 'legal_relationship_cluster', 'power_group_active', 'power_group_membership')
ORDER BY table_name;
 table_schema |         table_name         | table_type 
--------------+----------------------------+------------
 public       | legal_relationship_cluster | VIEW
 public       | power_group_active         | VIEW
 public       | power_group_def            | VIEW
 public       | power_group_membership     | VIEW
(4 rows)

-- ============================================================================
\echo "=== Section 2: Create Test Legal Units ==="
"=== Section 2: Create Test Legal Units ==="
-- ============================================================================
\echo "Create enterprises for our test legal units"
"Create enterprises for our test legal units"
INSERT INTO public.enterprise (short_name, edit_by_user_id, edit_comment)
SELECT 'PW' || n, (SELECT id FROM auth.user LIMIT 1), 'Power test enterprise ' || n
FROM generate_series(1, 6) AS n;
\echo "Create legal units with hierarchical parent-subsidiary structure"
"Create legal units with hierarchical parent-subsidiary structure"
-- Parent company (will be root of power group)
INSERT INTO public.legal_unit (
    valid_from, name, enterprise_id, primary_for_enterprise, 
    status_id, edit_by_user_id, edit_comment
)
SELECT 
    '2020-01-01'::date,
    'PowerTest Holdings Corp',
    (SELECT id FROM public.enterprise WHERE short_name = 'PW1'),
    true,
    (SELECT id FROM public.status WHERE code = 'active' LIMIT 1),
    (SELECT id FROM auth.user LIMIT 1),
    'Parent holding company';
-- Subsidiary 1 (directly owned by Holdings)
INSERT INTO public.legal_unit (
    valid_from, name, enterprise_id, primary_for_enterprise, 
    status_id, edit_by_user_id, edit_comment
)
SELECT 
    '2020-01-01'::date,
    'PowerTest Manufacturing Ltd',
    (SELECT id FROM public.enterprise WHERE short_name = 'PW2'),
    true,
    (SELECT id FROM public.status WHERE code = 'active' LIMIT 1),
    (SELECT id FROM auth.user LIMIT 1),
    'Manufacturing subsidiary';
-- Subsidiary 2 (directly owned by Holdings)
INSERT INTO public.legal_unit (
    valid_from, name, enterprise_id, primary_for_enterprise, 
    status_id, edit_by_user_id, edit_comment
)
SELECT 
    '2020-01-01'::date,
    'PowerTest Services Inc',
    (SELECT id FROM public.enterprise WHERE short_name = 'PW3'),
    true,
    (SELECT id FROM public.status WHERE code = 'active' LIMIT 1),
    (SELECT id FROM auth.user LIMIT 1),
    'Services subsidiary';
-- Sub-subsidiary (owned by Manufacturing - creating depth)
INSERT INTO public.legal_unit (
    valid_from, name, enterprise_id, primary_for_enterprise, 
    status_id, edit_by_user_id, edit_comment
)
SELECT 
    '2020-01-01'::date,
    'PowerTest Components GmbH',
    (SELECT id FROM public.enterprise WHERE short_name = 'PW4'),
    true,
    (SELECT id FROM public.status WHERE code = 'active' LIMIT 1),
    (SELECT id FROM auth.user LIMIT 1),
    'Components sub-subsidiary';
-- Independent company (not in any power group)
INSERT INTO public.legal_unit (
    valid_from, name, enterprise_id, primary_for_enterprise, 
    status_id, edit_by_user_id, edit_comment
)
SELECT 
    '2020-01-01'::date,
    'PowerTest Independent LLC',
    (SELECT id FROM public.enterprise WHERE short_name = 'PW5'),
    true,
    (SELECT id FROM public.status WHERE code = 'active' LIMIT 1),
    (SELECT id FROM auth.user LIMIT 1),
    'Independent company - no power group';
\echo "Verify legal units created"
"Verify legal units created"
SELECT name 
FROM public.legal_unit 
WHERE name LIKE 'PowerTest%'
ORDER BY name;
            name             
-----------------------------
 PowerTest Components GmbH
 PowerTest Holdings Corp
 PowerTest Independent LLC
 PowerTest Manufacturing Ltd
 PowerTest Services Inc
(5 rows)

-- ============================================================================
\echo "=== Section 3: Create Ownership Relationships (triggers worker task) ==="
"=== Section 3: Create Ownership Relationships (triggers worker task) ==="
-- ============================================================================
\echo "Create parent_company: Holdings is parent of Manufacturing (60%)"
"Create parent_company: Holdings is parent of Manufacturing (60%)"
INSERT INTO public.legal_relationship (
    valid_from, 
    influencing_id, 
    influenced_id, 
    type_id,
    percentage,
    edit_by_user_id,
    edit_comment
)
SELECT 
    '2020-01-01'::date,
    (SELECT id FROM public.legal_unit WHERE name = 'PowerTest Holdings Corp' LIMIT 1),
    (SELECT id FROM public.legal_unit WHERE name = 'PowerTest Manufacturing Ltd' LIMIT 1),
    (SELECT id FROM public.legal_rel_type WHERE code = 'parent_company'),
    60.00,
    (SELECT id FROM auth.user LIMIT 1),
    'Holdings owns 60% of Manufacturing';
\echo "Create parent_company: Holdings is parent of Services (51%)"
"Create parent_company: Holdings is parent of Services (51%)"
INSERT INTO public.legal_relationship (
    valid_from, 
    influencing_id, 
    influenced_id, 
    type_id,
    percentage,
    edit_by_user_id,
    edit_comment
)
SELECT 
    '2020-01-01'::date,
    (SELECT id FROM public.legal_unit WHERE name = 'PowerTest Holdings Corp' LIMIT 1),
    (SELECT id FROM public.legal_unit WHERE name = 'PowerTest Services Inc' LIMIT 1),
    (SELECT id FROM public.legal_rel_type WHERE code = 'parent_company'),
    51.00,
    (SELECT id FROM auth.user LIMIT 1),
    'Holdings owns 51% of Services';
\echo "Create parent_company: Manufacturing is parent of Components (75%)"
"Create parent_company: Manufacturing is parent of Components (75%)"
INSERT INTO public.legal_relationship (
    valid_from, 
    influencing_id, 
    influenced_id, 
    type_id,
    percentage,
    edit_by_user_id,
    edit_comment
)
SELECT 
    '2020-01-01'::date,
    (SELECT id FROM public.legal_unit WHERE name = 'PowerTest Manufacturing Ltd' LIMIT 1),
    (SELECT id FROM public.legal_unit WHERE name = 'PowerTest Components GmbH' LIMIT 1),
    (SELECT id FROM public.legal_rel_type WHERE code = 'parent_company'),
    75.00,
    (SELECT id FROM auth.user LIMIT 1),
    'Manufacturing owns 75% of Components';
-- ============================================================================
\echo "=== Section 4: Test Hierarchy View ==="
"=== Section 4: Test Hierarchy View ==="
-- ============================================================================
\echo "Check power_group_membership view (before worker runs)"
"Check power_group_membership view (before worker runs)"
SELECT
    lu.name,
    pgm.power_level,
    pgm.power_group_ident
FROM public.power_group_membership AS pgm
JOIN public.legal_unit AS lu ON lu.id = pgm.legal_unit_id AND lu.valid_range && pgm.valid_range
WHERE lu.name LIKE 'PowerTest%'
ORDER BY pgm.power_level, lu.name;
 name | power_level | power_group_ident 
------+-------------+-------------------
(0 rows)

\echo "Check power_group_def view (computes what power groups should exist)"
"Check power_group_def view (computes what power groups should exist)"
SELECT
    lu.name AS root_legal_unit,
    pgd.depth,
    pgd.width,
    pgd.reach
FROM public.power_group_def AS pgd
JOIN public.power_group_membership AS pgm ON pgm.power_group_id = pgd.power_group_id AND pgm.power_level = 1
JOIN public.legal_unit AS lu ON lu.id = pgm.legal_unit_id
WHERE lu.name LIKE 'PowerTest%';
 root_legal_unit | depth | width | reach 
-----------------+-------+-------+-------
(0 rows)

-- ============================================================================
\echo "=== Section 5: Run Worker Derivation ==="
"=== Section 5: Run Worker Derivation ==="
-- ============================================================================
\echo "Relationships BEFORE worker derivation (derived_power_group_id should be NULL)"
"Relationships BEFORE worker derivation (derived_power_group_id should be NULL)"
SELECT 
    influencer.name AS influencing_name,
    influenced.name AS influenced_name,
    lr.derived_power_group_id IS NOT NULL AS has_power_group,
    lr.percentage
FROM public.legal_relationship AS lr
JOIN public.legal_unit AS influencer ON lr.influencing_id = influencer.id
JOIN public.legal_unit AS influenced ON lr.influenced_id = influenced.id
WHERE influencer.name LIKE 'PowerTest%' OR influenced.name LIKE 'PowerTest%'
ORDER BY influencer.name, influenced.name;
      influencing_name       |       influenced_name       | has_power_group | percentage 
-----------------------------+-----------------------------+-----------------+------------
 PowerTest Holdings Corp     | PowerTest Manufacturing Ltd | f               |      60.00
 PowerTest Holdings Corp     | PowerTest Services Inc      | f               |      51.00
 PowerTest Manufacturing Ltd | PowerTest Components GmbH   | f               |      75.00
(3 rows)

\echo "Power groups BEFORE worker derivation (should be empty)"
"Power groups BEFORE worker derivation (should be empty)"
SELECT pg.ident, pg.name
FROM public.power_group AS pg
WHERE pg.name LIKE 'PowerTest%' OR pg.ident IS NOT NULL;
 ident | name 
-------+------
(0 rows)

\echo "Run process_power_group_link to create/link power groups"
"Run process_power_group_link to create/link power groups"
CALL import.process_power_group_link(NULL, NULL, 'process_power_group_link');
\echo "Power groups AFTER worker derivation"
"Power groups AFTER worker derivation"
SELECT pg.ident, pg.ident ~ '^PG[0-9A-Z]+$' AS valid_ident_format, pg.name
FROM public.power_group AS pg;
 ident  | valid_ident_format | name 
--------+--------------------+------
 PG0001 | t                  | 
(1 row)

\echo "Relationships AFTER worker derivation (should have derived_power_group_id)"
"Relationships AFTER worker derivation (should have derived_power_group_id)"
SELECT 
    influencer.name AS influencing_name,
    influenced.name AS influenced_name,
    pg.ident AS power_group_ident,
    lr.percentage
FROM public.legal_relationship AS lr
JOIN public.legal_unit AS influencer ON lr.influencing_id = influencer.id
JOIN public.legal_unit AS influenced ON lr.influenced_id = influenced.id
LEFT JOIN public.power_group AS pg ON lr.derived_power_group_id = pg.id
WHERE influencer.name LIKE 'PowerTest%' OR influenced.name LIKE 'PowerTest%'
ORDER BY influencer.name, influenced.name;
      influencing_name       |       influenced_name       | power_group_ident | percentage 
-----------------------------+-----------------------------+-------------------+------------
 PowerTest Holdings Corp     | PowerTest Manufacturing Ltd | PG0001            |      60.00
 PowerTest Holdings Corp     | PowerTest Services Inc      | PG0001            |      51.00
 PowerTest Manufacturing Ltd | PowerTest Components GmbH   | PG0001            |      75.00
(3 rows)

-- ============================================================================
\echo "=== Section 6: Verify Hierarchy via Views ==="
"=== Section 6: Verify Hierarchy via Views ==="
-- ============================================================================
\echo "Check power_group_membership after derivation"
"Check power_group_membership after derivation"
SELECT
    lu.name,
    pgm.power_level,
    pgm.power_group_ident
FROM public.power_group_membership AS pgm
JOIN public.legal_unit AS lu ON lu.id = pgm.legal_unit_id
WHERE lu.name LIKE 'PowerTest%'
ORDER BY pgm.power_level, lu.name;
            name             | power_level | power_group_ident 
-----------------------------+-------------+-------------------
 PowerTest Holdings Corp     |           1 | PG0001
 PowerTest Manufacturing Ltd |           2 | PG0001
 PowerTest Services Inc      |           2 | PG0001
 PowerTest Components GmbH   |           3 | PG0001
(4 rows)

\echo "Holdings should be level 1 (root)"
"Holdings should be level 1 (root)"
SELECT lu.name, pgm.power_level
FROM public.power_group_membership AS pgm
JOIN public.legal_unit AS lu ON lu.id = pgm.legal_unit_id
WHERE lu.name = 'PowerTest Holdings Corp';
          name           | power_level 
-------------------------+-------------
 PowerTest Holdings Corp |           1
(1 row)

\echo "Manufacturing and Services should be level 2 (direct subsidiaries)"
"Manufacturing and Services should be level 2 (direct subsidiaries)"
SELECT lu.name, pgm.power_level
FROM public.power_group_membership AS pgm
JOIN public.legal_unit AS lu ON lu.id = pgm.legal_unit_id
WHERE lu.name IN ('PowerTest Manufacturing Ltd', 'PowerTest Services Inc')
ORDER BY lu.name;
            name             | power_level 
-----------------------------+-------------
 PowerTest Manufacturing Ltd |           2
 PowerTest Services Inc      |           2
(2 rows)

\echo "Components should be level 3 (sub-subsidiary)"
"Components should be level 3 (sub-subsidiary)"
SELECT lu.name, pgm.power_level
FROM public.power_group_membership AS pgm
JOIN public.legal_unit AS lu ON lu.id = pgm.legal_unit_id
WHERE lu.name = 'PowerTest Components GmbH';
           name            | power_level 
---------------------------+-------------
 PowerTest Components GmbH |           3
(1 row)

\echo "Independent should NOT be in hierarchy"
"Independent should NOT be in hierarchy"
SELECT lu.name, pgm.power_level
FROM public.legal_unit AS lu
LEFT JOIN public.power_group_membership AS pgm ON lu.id = pgm.legal_unit_id
WHERE lu.name = 'PowerTest Independent LLC';
           name            | power_level 
---------------------------+-------------
 PowerTest Independent LLC |            
(1 row)

-- ============================================================================
\echo "=== Section 7: Verify Power Group Metrics via View ==="
"=== Section 7: Verify Power Group Metrics via View ==="
-- ============================================================================
\echo "Verify depth, width, reach from power_group_def view"
"Verify depth, width, reach from power_group_def view"
SELECT 
    lu.name AS root_legal_unit,
    pgd.depth,
    pgd.depth = 2 AS correct_depth,  -- Holdings -> Manufacturing -> Components = 2 levels
    pgd.width,
    pgd.width = 2 AS correct_width,  -- Holdings has 2 direct children
    pgd.reach,
    pgd.reach = 3 AS correct_reach   -- Manufacturing, Services, Components = 3 total
FROM public.power_group_def AS pgd
JOIN public.power_group_membership AS pgm ON pgm.power_group_id = pgd.power_group_id AND pgm.power_level = 1
JOIN public.legal_unit AS lu ON lu.id = pgm.legal_unit_id
WHERE lu.name = 'PowerTest Holdings Corp';
     root_legal_unit     | depth | correct_depth | width | correct_width | reach | correct_reach 
-------------------------+-------+---------------+-------+---------------+-------+---------------
 PowerTest Holdings Corp |     2 | t             |     2 | t             |     3 | t
(1 row)

-- ============================================================================
\echo "=== Section 8: Test Non-Controlling Ownership ==="
"=== Section 8: Test Non-Controlling Ownership ==="
-- ============================================================================
\echo "Create a second hierarchy root (new company owning Independent with <50%)"
"Create a second hierarchy root (new company owning Independent with <50%)"
INSERT INTO public.legal_unit (
    valid_from, name, enterprise_id, primary_for_enterprise, 
    status_id, edit_by_user_id, edit_comment
)
SELECT 
    '2020-01-01'::date,
    'PowerTest MinorInvestor Corp',
    (SELECT id FROM public.enterprise WHERE short_name = 'PW6'),
    true,
    (SELECT id FROM public.status WHERE code = 'active' LIMIT 1),
    (SELECT id FROM auth.user LIMIT 1),
    'Minor investor company';
\echo "Create non-primary-influencer relationship: MinorInvestor co-owns Independent"
"Create non-primary-influencer relationship: MinorInvestor co-owns Independent"
INSERT INTO public.legal_relationship (
    valid_from,
    influencing_id,
    influenced_id,
    type_id,
    percentage,
    edit_by_user_id,
    edit_comment
)
SELECT
    '2020-01-01'::date,
    (SELECT id FROM public.legal_unit WHERE name = 'PowerTest MinorInvestor Corp' LIMIT 1),
    (SELECT id FROM public.legal_unit WHERE name = 'PowerTest Independent LLC' LIMIT 1),
    (SELECT id FROM public.legal_rel_type WHERE code = 'co_ownership'),
    30.00,  -- co_ownership type has primary_influencer_only = FALSE, so not in power group
    (SELECT id FROM auth.user LIMIT 1),
    'MinorInvestor co-owns Independent (not primary_influencer_only)';
\echo "Re-run process_power_group_link"
"Re-run process_power_group_link"
CALL import.process_power_group_link(NULL, NULL, 'process_power_group_link');
\echo "Non-primary-influencer relationship should have NULL derived_power_group_id"
"Non-primary-influencer relationship should have NULL derived_power_group_id"
SELECT 
    influencer.name AS influencing_name,
    influenced.name AS influenced_name,
    lr.derived_power_group_id IS NULL AS no_power_group,
    lr.percentage
FROM public.legal_relationship AS lr
JOIN public.legal_unit AS influencer ON lr.influencing_id = influencer.id
JOIN public.legal_unit AS influenced ON lr.influenced_id = influenced.id
WHERE influencer.name = 'PowerTest MinorInvestor Corp';
       influencing_name       |      influenced_name      | no_power_group | percentage 
------------------------------+---------------------------+----------------+------------
 PowerTest MinorInvestor Corp | PowerTest Independent LLC | f              |      30.00
(1 row)

\echo "Independent and MinorInvestor should NOT be in power hierarchy"
"Independent and MinorInvestor should NOT be in power hierarchy"
SELECT lu.name, pgm.power_level
FROM public.legal_unit AS lu
LEFT JOIN public.power_group_membership AS pgm ON lu.id = pgm.legal_unit_id
WHERE lu.name IN ('PowerTest Independent LLC', 'PowerTest MinorInvestor Corp')
ORDER BY lu.name;
             name             | power_level 
------------------------------+-------------
 PowerTest Independent LLC    |           2
 PowerTest MinorInvestor Corp |           1
(2 rows)

-- ============================================================================
\echo "=== Section 9: Test Idempotency ==="
"=== Section 9: Test Idempotency ==="
-- ============================================================================
\echo "Run process_power_group_link again (should not change anything)"
"Run process_power_group_link again (should not change anything)"
CALL import.process_power_group_link(NULL, NULL, 'process_power_group_link');
\echo "Verify power groups unchanged"
"Verify power groups unchanged"
SELECT pg.ident, pg.ident ~ '^PG[0-9A-Z]+$' AS valid_ident_format
FROM public.power_group AS pg;
 ident  | valid_ident_format 
--------+--------------------
 PG0001 | t
 PG0002 | t
(2 rows)

\echo "Verify relationships unchanged"
"Verify relationships unchanged"
SELECT 
    influencer.name AS influencing_name,
    influenced.name AS influenced_name,
    pg.ident AS power_group_ident
FROM public.legal_relationship AS lr
JOIN public.legal_unit AS influencer ON lr.influencing_id = influencer.id
JOIN public.legal_unit AS influenced ON lr.influenced_id = influenced.id
LEFT JOIN public.power_group AS pg ON lr.derived_power_group_id = pg.id
WHERE influencer.name LIKE 'PowerTest%'
ORDER BY influencer.name, influenced.name;
       influencing_name       |       influenced_name       | power_group_ident 
------------------------------+-----------------------------+-------------------
 PowerTest Holdings Corp      | PowerTest Manufacturing Ltd | PG0001
 PowerTest Holdings Corp      | PowerTest Services Inc      | PG0001
 PowerTest Manufacturing Ltd  | PowerTest Components GmbH   | PG0001
 PowerTest MinorInvestor Corp | PowerTest Independent LLC   | PG0002
(4 rows)

-- ============================================================================
\echo "=== Section 10: Test power_group_active View ==="
"=== Section 10: Test power_group_active View ==="
-- ============================================================================
\echo "Check currently active power groups"
"Check currently active power groups"
SELECT ident, name
FROM public.power_group_active
ORDER BY ident;
 ident  | name 
--------+------
 PG0001 | 
 PG0002 | 
(2 rows)

-- ============================================================================
\echo "=== Section 11: Summary ==="
"=== Section 11: Summary ==="
-- ============================================================================
\echo "All power groups (timeless registry)"
"All power groups (timeless registry)"
SELECT pg.ident, pg.ident ~ '^PG[0-9A-Z]+$' AS valid_ident_format, pg.name
FROM public.power_group AS pg
ORDER BY pg.ident;
 ident  | valid_ident_format | name 
--------+--------------------+------
 PG0001 | t                  | 
 PG0002 | t                  | 
(2 rows)

\echo "All relationships with power group assignment"
"All relationships with power group assignment"
SELECT 
    pg.ident AS power_group,
    COUNT(*) AS relationship_count
FROM public.legal_relationship AS lr
JOIN public.legal_unit AS influencer ON lr.influencing_id = influencer.id
LEFT JOIN public.power_group AS pg ON lr.derived_power_group_id = pg.id
WHERE influencer.name LIKE 'PowerTest%'
GROUP BY pg.ident
ORDER BY pg.ident NULLS LAST;
 power_group | relationship_count 
-------------+--------------------
 PG0001      |                  3
 PG0002      |                  1
(2 rows)

\echo "Legal units by power level (from membership view)"
"Legal units by power level (from membership view)"
SELECT
    pgm.power_level,
    COUNT(*) AS count,
    string_agg(lu.name, ', ' ORDER BY lu.name) AS names
FROM public.power_group_membership AS pgm
JOIN public.legal_unit AS lu ON lu.id = pgm.legal_unit_id
WHERE lu.name LIKE 'PowerTest%'
GROUP BY pgm.power_level
ORDER BY pgm.power_level;
 power_level | count |                                     names                                      
-------------+-------+--------------------------------------------------------------------------------
           1 |     2 | PowerTest Holdings Corp, PowerTest MinorInvestor Corp
           2 |     3 | PowerTest Independent LLC, PowerTest Manufacturing Ltd, PowerTest Services Inc
           3 |     1 | PowerTest Components GmbH
(3 rows)

\echo "=== Power Group Worker Derivation Test Complete ==="
"=== Power Group Worker Derivation Test Complete ==="
ROLLBACK;
