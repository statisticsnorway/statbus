\echo "Task payload: PG batch should have power_group_ids but no enterprise_ids"
"Task payload: PG batch should have power_group_ids but no enterprise_ids"
SELECT
    payload ? 'power_group_ids' AS has_pg_ids,
    payload ? 'enterprise_ids' AS has_ent_ids
FROM worker.tasks
WHERE command = 'statistical_unit_refresh_batch'
  AND state = 'completed'
  AND payload ? 'power_group_ids' AND NOT (payload ? 'enterprise_ids')
ORDER BY id DESC LIMIT 1;
 has_pg_ids | has_ent_ids 
------------+-------------
 t          | f
(1 row)

\echo "Clean up for next test"
"Clean up for next test"
DELETE FROM worker.tasks WHERE state = 'completed';
--------------------------------------------------------------------------------
\echo "--- TEST J: LU migration between enterprises (connect_legal_unit_to_enterprise) ---"
"--- TEST J: LU migration between enterprises (connect_legal_unit_to_enterprise) ---"
--------------------------------------------------------------------------------
-- Moving a LU between enterprises should propagate changes to both old and new EN.
\echo "Step 1: Identify two LUs in different enterprises"
"Step 1: Identify two LUs in different enterprises"
-- Use SSB Updated (already modified in earlier tests) and another LU
SELECT lu.id AS lu_id, lu.name, lu.enterprise_id
FROM public.legal_unit AS lu
WHERE lu.name = 'SSB Updated'
AND lu.valid_from <= current_date AND current_date < lu.valid_until;
 lu_id |    name     | enterprise_id 
-------+-------------+---------------
    15 | SSB Updated |            22
(1 row)

-- Pick a target enterprise different from SSB Updated's enterprise
SELECT lu2.enterprise_id AS target_enterprise_id
FROM public.legal_unit AS lu2
WHERE lu2.enterprise_id != (SELECT enterprise_id FROM public.legal_unit WHERE name = 'SSB Updated' LIMIT 1)
  AND lu2.valid_from <= current_date AND current_date < lu2.valid_until
ORDER BY lu2.id
LIMIT 1;
 target_enterprise_id 
----------------------
                    1
(1 row)

-- Drop leftover temp tables from temporal_merge (created by SECURITY DEFINER
-- import functions as postgres; current role can't drop them)
RESET ROLE;
DROP TABLE IF EXISTS pg_temp.temporal_merge_plan;
DROP TABLE IF EXISTS pg_temp.temporal_merge_feedback;
DROP TABLE IF EXISTS pg_temp.temporal_merge_entity_id_map;
NOTICE:  table "temporal_merge_entity_id_map" does not exist, skipping
DROP TABLE IF EXISTS pg_temp.temporal_merge_index_cache;
CALL test.set_user_from_email('test.admin@statbus.org');
\echo "Step 2: Move SSB Updated to the target enterprise"
"Step 2: Move SSB Updated to the target enterprise"
SELECT connect_legal_unit_to_enterprise(
    legal_unit_id := lu.id,
    enterprise_id := target_en.enterprise_id
)
FROM public.legal_unit AS lu
CROSS JOIN (
    SELECT lu2.enterprise_id
    FROM public.legal_unit AS lu2
    WHERE lu2.enterprise_id != (SELECT enterprise_id FROM public.legal_unit WHERE name = 'SSB Updated' LIMIT 1)
      AND lu2.valid_from <= current_date AND current_date < lu2.valid_until
    ORDER BY lu2.id LIMIT 1
) AS target_en
WHERE lu.name = 'SSB Updated'
  AND lu.valid_from <= current_date AND current_date < lu.valid_until;
                                         connect_legal_unit_to_enterprise                                         
------------------------------------------------------------------------------------------------------------------
 {"new_enterprise_id": 1, "old_enterprise_id": 22, "deleted_enterprise_id": null, "updated_legal_unit_ids": [15]}
(1 row)

\echo "Check: Expect one collect_changes task"
"Check: Expect one collect_changes task"
SELECT command, state FROM worker.tasks WHERE command = 'collect_changes' AND state = 'pending';
     command     |  state  
-----------------+---------
 collect_changes | pending
(1 row)

\echo "Run analytics worker"
"Run analytics worker"
CALL worker.process_tasks(p_queue => 'analytics');
