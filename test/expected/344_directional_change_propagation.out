WARNING:  Error in before_procedure worker.notify_task_progress for task 2723: worker.notify_task_progress() is not a procedure
DELETE FROM worker.tasks WHERE state = 'completed';
\echo "Check: power_root rows exist after cycle creation"
"Check: power_root rows exist after cycle creation"
