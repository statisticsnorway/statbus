\echo "Test yearly data"
"Test yearly data"
SELECT year
     , unit_type
     , exists_count
     , exists_change
     , exists_added_count
     , exists_removed_count
     , countable_count
     , countable_change
     , countable_added_count
     , countable_removed_count
FROM public.statistical_history
WHERE resolution = 'year'
  AND year <= 2024
ORDER BY year,unit_type;
