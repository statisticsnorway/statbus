\echo 'Test Case 7: Demonstrate necessity of `process_*` call ordering with SAVEPOINTs'
Test Case 7: Demonstrate necessity of `process_*` call ordering with SAVEPOINTs
CALL set_test_orchestrator.reset_target();
CREATE TEMP TABLE temp_source ( row_id INT, legal_unit_id INT, id INT, valid_after DATE NOT NULL, valid_to DATE NOT NULL, name TEXT, employees INT, edit_comment TEXT ) ON COMMIT DROP;
SAVEPOINT before_wrong_order;
\echo '--- Stage 1: Prove that UPDATE-before-INSERT fails (data loss) ---'
--- Stage 1: Prove that UPDATE-before-INSERT fails (data loss) ---
INSERT INTO temp_source VALUES (301, 1, 3, '2021-12-31', '2022-12-31', 'NewCo UPDATE', 15, 'Should not be inserted');
\echo 'Calling orchestrator with UPDATE on non-existent entity...'
Calling orchestrator with UPDATE on non-existent entity...
\echo 'Expected orchestrator feedback (SUCCESS with no entity ID):'
Expected orchestrator feedback (SUCCESS with no entity ID):
SELECT * FROM (VALUES (301, '[]'::JSONB, 'SUCCESS'::TEXT, NULL::TEXT)) AS t (source_row_id, target_entity_ids, status, error_message);
 source_row_id | target_entity_ids | status  | error_message 
---------------+-------------------+---------+---------------
           301 | []                | SUCCESS | 
-- So the empty target_entity_ids signals an error?
(1 row)

\echo 'Actual orchestrator feedback:'
Actual orchestrator feedback:
SELECT source_row_id, target_entity_ids, status, error_message FROM import.set_insert_or_update_generic_valid_time_table(:'target_schema', :'target_table', :'source_schema', 'temp_source', :'entity_id_cols'::TEXT[], NULL, :'ephemeral_cols'::TEXT[]);
 source_row_id | target_entity_ids | status  | error_message 
---------------+-------------------+---------+---------------
           301 | [{"id": 3}]       | SUCCESS | 
-- This does not match the expected - and there is no semantic clue anything is lost?
(1 row)

\echo 'Final state of target table (expected empty, proving data loss):'
Final state of target table (expected empty, proving data loss):
SELECT 0 as row_count WHERE NOT EXISTS (SELECT 1 FROM set_test_orchestrator.establishment WHERE id = 3);
 row_count 
-----------
(0 rows)

\echo 'Actual state of target table:'
Actual state of target table:
SELECT count(*) as row_count FROM set_test_orchestrator.establishment WHERE id = 3;
 row_count 
-----------
         1
(1 row)

ROLLBACK TO SAVEPOINT before_wrong_order;
\echo '--- Stage 2: Prove that INSERT-then-UPDATE succeeds ---'
--- Stage 2: Prove that INSERT-then-UPDATE succeeds ---
\echo 'Calling orchestrator with INSERT...'
Calling orchestrator with INSERT...
TRUNCATE temp_source;
INSERT INTO temp_source VALUES
(202, 1, 1, '2021-12-31', '2022-06-30', 'NewCo', 15, 'Update A'), -- These two will be merged
(203, 1, 1, '2022-06-30', '2022-12-31', 'NewCo', 15, 'Update B');
\echo 'Calling orchestrator for UPDATEs...'
Calling orchestrator for UPDATEs...
\echo 'Expected orchestrator feedback for UPDATEs (SUCCESS for both merged rows):'
Expected orchestrator feedback for UPDATEs (SUCCESS for both merged rows):
SELECT * FROM (VALUES
    (202, '{"id": 1}'::JSONB, 'SUCCESS'::TEXT, NULL::TEXT),
    (203, '{"id": 1}'::JSONB, 'SUCCESS'::TEXT, NULL::TEXT)
) AS t (source_row_id, target_entity_ids, status, error_message);
 source_row_id | target_entity_ids | status  | error_message 
---------------+-------------------+---------+---------------
           202 | {"id": 1}         | SUCCESS | 
           203 | {"id": 1}         | SUCCESS | 
(2 rows)

\echo 'Actual orchestrator feedback for UPDATEs:'
Actual orchestrator feedback for UPDATEs:
SELECT source_row_id, target_entity_ids, status, error_message FROM import.set_insert_or_update_generic_valid_time_table(:'target_schema', :'target_table', :'source_schema', 'temp_source', :'entity_id_cols'::TEXT[], NULL, :'ephemeral_cols'::TEXT[]) ORDER BY source_row_id;
 source_row_id | target_entity_ids | status  | error_message 
---------------+-------------------+---------+---------------
           202 | [{"id": 1}]       | SUCCESS | 
           203 | [{"id": 1}]       | SUCCESS | 
(2 rows)

\echo 'Final state of target table (expected a complete history):'
Final state of target table (expected a complete history):
SELECT * FROM (VALUES
    (1, 1, '2020-12-31'::DATE, '2021-12-31'::DATE, 'NewCo'::TEXT, 10, 'Initial Insert'::TEXT),
    (1, 1, '2021-12-31'::DATE, '2022-12-31'::DATE, 'NewCo'::TEXT, 15, 'Update B'::TEXT)
) AS t (id, legal_unit_id, valid_after, valid_to, name, employees, edit_comment);
 id | legal_unit_id | valid_after |  valid_to  | name  | employees |  edit_comment  
----+---------------+-------------+------------+-------+-----------+----------------
  1 |             1 | 2020-12-31  | 2021-12-31 | NewCo |        10 | Initial Insert
  1 |             1 | 2021-12-31  | 2022-12-31 | NewCo |        15 | Update B
(2 rows)

\echo 'Actual state of target table:'
Actual state of target table:
SELECT id, legal_unit_id, valid_after, valid_to, name, employees, edit_comment FROM set_test_orchestrator.establishment WHERE id = 1 ORDER BY valid_after;
 id | legal_unit_id | valid_after |  valid_to  | name  | employees |  edit_comment  
----+---------------+-------------+------------+-------+-----------+----------------
  1 |             1 | 2020-12-31  | 2021-12-31 | NewCo |        10 | Initial Insert
  1 |             1 | 2021-12-31  | 2022-12-31 | NewCo |        15 | Update B
(2 rows)

RELEASE SAVEPOINT before_wrong_order;
DROP TABLE temp_source;
-- Cleanup
DROP PROCEDURE set_test_orchestrator.reset_target();
DROP TABLE set_test_orchestrator.establishment;
DROP TABLE set_test_orchestrator.legal_unit;
DROP SEQUENCE set_test_orchestrator.establishment_id_seq;
DROP SEQUENCE set_test_orchestrator.legal_unit_id_seq;
DROP SCHEMA set_test_orchestrator CASCADE;
SET client_min_messages TO NOTICE;
ROLLBACK;
