-- Helper procedure to reset the target table for a new scenario
CREATE OR REPLACE PROCEDURE set_test_merge_composite.reset_target() AS $$
BEGIN
    TRUNCATE set_test_merge_composite.stat_definition, set_test_merge_composite.establishment, set_test_merge_composite.stat_for_unit, set_test_merge_composite.stat_for_unit_with_id, set_test_merge_composite.stat_for_unit_with_identity, set_test_merge_composite.stat_for_unit_no_pk RESTART IDENTITY CASCADE;
    -- Add parent data
    INSERT INTO set_test_merge_composite.stat_definition (id, name) VALUES (10, 'Total Employees');
    INSERT INTO set_test_merge_composite.establishment (id, valid_after, valid_to, name) VALUES (100, '1900-01-01', 'infinity', 'EST 100');
END;
$$ LANGUAGE plpgsql;
\set source_schema 'pg_temp'
\set ephemeral_cols '{edit_comment}'
--------------------------------------------------------------------------------
\echo 'Scenario 1: `upsert_replace` with a composite key (`during` split)'
Scenario 1: `upsert_replace` with a composite key (`during` split)
--------------------------------------------------------------------------------
CALL set_test_merge_composite.reset_target();
INSERT INTO set_test_merge_composite.stat_for_unit (stat_definition_id, establishment_id, valid_after, valid_to, value, edit_comment) VALUES
(10, 100, '2024-01-01', '2024-12-31', 50, 'Original Value');
CREATE TEMP TABLE temp_source_1 (
    row_id INT, stat_definition_id INT, establishment_id INT, valid_after DATE NOT NULL, valid_to DATE NOT NULL, value BIGINT, edit_comment TEXT
) ON COMMIT DROP;
INSERT INTO temp_source_1 VALUES (1, 10, 100, '2024-04-01', '2024-08-31', 55, 'Corrected value for mid-year');
-- Run the orchestrator and store its feedback
