-- Test: BEFORE-INSERT-OR-UPDATE trigger upgrade_block_obsolete_pending_trigger
--       and backstop procedure upgrade_reap_ancestors_of_completed.
--
-- The trigger enforces the cross-row invariant:
--   "no available/scheduled row may be a strict ancestor of a completed
--    row whose release_status is greater than or equal to its own."
--
-- Auto-supersede on insert preserves audit trail (the row exists, with
-- state=superseded and superseded_at timestamp) — vs erroring, which
-- would lose the row entirely.
--
-- Coverage:
--   T1. Insert obsolete-ancestor available row → trigger flips to superseded
--   T2. Hierarchy guard: tagged prerelease NOT auto-superseded by older
--       commit-status completed row
--   T3. Insert with state=completed → trigger no-op (terminal state)
--   T4. UPDATE state to available on a row that is now obsolete → trigger fires
--   T5. UPDATE release_status promotes a row that becomes obsolete → trigger fires
--   T6. Backstop procedure: with trigger temporarily disabled, manually
--       insert orphan ancestor; backstop reaps it
--   T7. Backstop is idempotent (second call returns 0 from outer count)
--   T8. STATBUS-154 constraint chk_upgrade_parked_requires_in_progress rejects
--       moving a parked row to a non-in_progress state (parked + completed = the
--       convicted corruption)
--   T9. STATBUS-154 instrumentation: each state/parked-changing UPDATE lands
--       exactly one public.upgrade_state_log row with the correct old→new state
--       and parked_at transitions; a non-changing UPDATE lands none
--   T10. STATBUS-160 trigger upgrade_block_terminal_resurrection REJECTS a
--        superseded → completed UPDATE (terminal rows are not resurrectable)
--   T11. STATBUS-160: available → completed is ALLOWED (install bookkeeping of a
--        never-attempted row)
--   T12. STATBUS-160: superseded → scheduled is ALLOWED (deliberate re-dispatch
--        stays legal)
--
-- Shared-test harness: wrap in BEGIN/ROLLBACK for cloned-template isolation.
BEGIN;
TRUNCATE public.upgrade RESTART IDENTITY;
\echo '=== T1: trigger flips obsolete-ancestor available row to superseded on insert ==='
=== T1: trigger flips obsolete-ancestor available row to superseded on insert ===
-- Anchor: a completed prerelease (the "running" row).
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, commit_tags, completed_at, log_relative_file_path)
VALUES (lpad(to_hex(100), 40, '0'), now(), 'prerelease', 'completed',
        'running v2026.04.0-rc.10', ARRAY['v2026.04.0-rc.10'], now(), 'log.txt');
-- Insert an older prerelease as available — trigger should auto-supersede it.
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, commit_tags)
VALUES (lpad(to_hex(50), 40, '0'), now() - '1 day'::interval, 'prerelease', 'available',
        'older retroactive tag v2026.04.0-rc.9', ARRAY['v2026.04.0-rc.9']);
SELECT id, commit_tags[1] AS tag, state, superseded_at IS NOT NULL AS has_superseded_at
  FROM public.upgrade ORDER BY id;
 id |       tag        |   state    | has_superseded_at 
----+------------------+------------+-------------------
  1 | v2026.04.0-rc.10 | completed  | f
  2 | v2026.04.0-rc.9  | superseded | t
(2 rows)

\echo '=== T2: hierarchy guard — tagged prerelease NOT auto-superseded by completed plain commit ==='
=== T2: hierarchy guard — tagged prerelease NOT auto-superseded by completed plain commit ===
TRUNCATE public.upgrade RESTART IDENTITY;
-- Anchor: a completed plain commit (release_status='commit').
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, completed_at, log_relative_file_path)
VALUES (lpad(to_hex(100), 40, '0'), now(), 'commit', 'completed',
        'running plain commit', now(), 'log.txt');
-- Insert an older PRERELEASE as available — must NOT be auto-superseded
-- because release_status='prerelease' > 'commit'. Tagged milestones beat
-- plain commits in the hierarchy.
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, commit_tags)
VALUES (lpad(to_hex(50), 40, '0'), now() - '1 day'::interval, 'prerelease', 'available',
        'older but tagged prerelease', ARRAY['v2026.04.0-rc.9']);
SELECT id, commit_tags[1] AS tag, release_status, state, superseded_at IS NOT NULL AS has_superseded_at
  FROM public.upgrade ORDER BY id;
 id |       tag       | release_status |   state   | has_superseded_at 
----+-----------------+----------------+-----------+-------------------
  1 |                 | commit         | completed | f
  2 | v2026.04.0-rc.9 | prerelease     | available | f
(2 rows)

\echo '=== T3: completed-state insert is a trigger no-op ==='
=== T3: completed-state insert is a trigger no-op ===
TRUNCATE public.upgrade RESTART IDENTITY;
-- Anchor: completed prerelease.
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, commit_tags, completed_at, log_relative_file_path)
VALUES (lpad(to_hex(100), 40, '0'), now(), 'prerelease', 'completed',
        'running v2026.04.0-rc.10', ARRAY['v2026.04.0-rc.10'], now(), 'log.txt');
-- Insert another completed row at older time — trigger only acts on
-- (available, scheduled). Completed rows pass through unchanged.
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, commit_tags, completed_at, log_relative_file_path)
VALUES (lpad(to_hex(50), 40, '0'), now() - '1 day'::interval, 'prerelease', 'completed',
        'older completed prerelease', ARRAY['v2026.04.0-rc.9'], now() - '1 day'::interval, 'log.txt');
SELECT id, commit_tags[1] AS tag, state, superseded_at IS NOT NULL AS has_superseded_at
  FROM public.upgrade ORDER BY id;
 id |       tag        |   state   | has_superseded_at 
----+------------------+-----------+-------------------
  1 | v2026.04.0-rc.10 | completed | f
  2 | v2026.04.0-rc.9  | completed | f
(2 rows)

\echo '=== T4: UPDATE state available → trigger fires when row becomes obsolete ==='
=== T4: UPDATE state available → trigger fires when row becomes obsolete ===
TRUNCATE public.upgrade RESTART IDENTITY;
-- Insert a not-yet-obsolete available row first (no completed anchor exists).
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, commit_tags)
VALUES (lpad(to_hex(50), 40, '0'), now() - '1 day'::interval, 'prerelease', 'available',
        'pre-existing available', ARRAY['v2026.04.0-rc.9']);
-- Now add the completed anchor.
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, commit_tags, completed_at, log_relative_file_path)
VALUES (lpad(to_hex(100), 40, '0'), now(), 'prerelease', 'completed',
        'running v2026.04.0-rc.10', ARRAY['v2026.04.0-rc.10'], now(), 'log.txt');
-- Force a "no-op" UPDATE on the available row's state — the trigger fires
-- because state is in the OF list, and now the row IS obsolete vs the
-- newly-arrived anchor. UPDATE sets state=state to drive the trigger.
UPDATE public.upgrade SET state = state WHERE id = 1;
SELECT id, commit_tags[1] AS tag, state, superseded_at IS NOT NULL AS has_superseded_at
  FROM public.upgrade ORDER BY id;
 id |       tag        |   state    | has_superseded_at 
----+------------------+------------+-------------------
  1 | v2026.04.0-rc.9  | superseded | t
  2 | v2026.04.0-rc.10 | completed  | f
(2 rows)

\echo '=== T5: UPDATE release_status promoting row that becomes obsolete ==='
=== T5: UPDATE release_status promoting row that becomes obsolete ===
TRUNCATE public.upgrade RESTART IDENTITY;
-- Anchor: completed prerelease.
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, commit_tags, completed_at, log_relative_file_path)
VALUES (lpad(to_hex(100), 40, '0'), now(), 'prerelease', 'completed',
        'running v2026.04.0-rc.10', ARRAY['v2026.04.0-rc.10'], now(), 'log.txt');
-- Available row with release_status='commit' — NOT obsolete vs the anchor
-- (anchor.release_status='prerelease' > 'commit', hierarchy lets it stay).
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary)
VALUES (lpad(to_hex(50), 40, '0'), now() - '1 day'::interval, 'commit', 'available',
        'plain commit, older');
SELECT id, release_status, state FROM public.upgrade ORDER BY id;
 id | release_status |   state    
----+----------------+------------
  1 | prerelease     | completed
  2 | commit         | superseded
(2 rows)

-- Promote the commit-status row to prerelease (e.g. tag landed on it).
-- After the promotion, the row IS obsolete (older than anchor with
-- release_status >= prerelease). Trigger should auto-supersede.
UPDATE public.upgrade SET release_status = 'prerelease' WHERE id = 2;
SELECT id, release_status, state, superseded_at IS NOT NULL AS has_superseded_at
  FROM public.upgrade ORDER BY id;
 id | release_status |   state    | has_superseded_at 
----+----------------+------------+-------------------
  1 | prerelease     | completed  | f
  2 | prerelease     | superseded | t
(2 rows)

\echo '=== T6: backstop procedure reaps trigger-bypassed orphan ==='
=== T6: backstop procedure reaps trigger-bypassed orphan ===
TRUNCATE public.upgrade RESTART IDENTITY;
-- Anchor: completed prerelease.
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, commit_tags, completed_at, log_relative_file_path)
VALUES (lpad(to_hex(100), 40, '0'), now(), 'prerelease', 'completed',
        'running', ARRAY['v2026.04.0-rc.10'], now(), 'log.txt');
-- Disable trigger to simulate a pre-trigger-era orphan landing in available.
ALTER TABLE public.upgrade DISABLE TRIGGER upgrade_block_obsolete_pending_trigger;
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, commit_tags)
VALUES (lpad(to_hex(50), 40, '0'), now() - '1 day'::interval, 'prerelease', 'available',
        'orphan ancestor', ARRAY['v2026.04.0-rc.9']);
ALTER TABLE public.upgrade ENABLE TRIGGER upgrade_block_obsolete_pending_trigger;
\echo 'before backstop:'
before backstop:
SELECT id, state FROM public.upgrade ORDER BY id;
 id |   state   
----+-----------
  1 | completed
  2 | available
(2 rows)

CALL public.upgrade_reap_ancestors_of_completed(0);
NOTICE:  upgrade_supersede_older: superseded 1 row(s) older than 0000000000000000000000000000000000000064 (status=prerelease)
NOTICE:  upgrade_reap_ancestors_of_completed: superseded 1 row(s)
 p_superseded 
--------------
            1
(1 row)

\echo 'after backstop:'
after backstop:
SELECT id, state, superseded_at IS NOT NULL AS has_superseded_at
  FROM public.upgrade ORDER BY id;
 id |   state    | has_superseded_at 
----+------------+-------------------
  1 | completed  | f
  2 | superseded | t
(2 rows)

\echo '=== T7: backstop is idempotent ==='
=== T7: backstop is idempotent ===
-- Already-superseded rows are not in supersede_older's WHERE filter;
-- re-running finds nothing to do.
CALL public.upgrade_reap_ancestors_of_completed(0);
 p_superseded 
--------------
            0
(1 row)

SELECT count(*) FILTER (WHERE state = 'superseded') AS superseded_count,
       count(*) FILTER (WHERE state = 'available')  AS available_count
  FROM public.upgrade;
 superseded_count | available_count 
------------------+-----------------
                1 |               0
(1 row)

\echo '=== T8: parked-requires-in_progress constraint rejects parked → non-in_progress ==='
=== T8: parked-requires-in_progress constraint rejects parked → non-in_progress ===
TRUNCATE public.upgrade RESTART IDENTITY;
-- A parked upgrade: STATBUS-046 keeps state='in_progress' (forward-only) with the
-- recovery-park marker set. This is the only state in which a park marker is legal.
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, scheduled_at, started_at, recovery_parked_at, recovery_parked_reason)
VALUES (lpad(to_hex(100), 40, '0'), now(), 'commit', 'in_progress',
        'parked at-target', now(), now(), now(), 'attempt budget exhausted at migrate');
-- Moving it to a terminal state while the park marker is still set is exactly the
-- corruption STATBUS-154 convicted (parked + completed). The row is made valid for
-- chk_upgrade_state_attributes as 'failed' (error set) so the ONLY constraint left
-- to fail is chk_upgrade_parked_requires_in_progress — its error is deterministic.
-- VERBOSITY terse: the ERROR line is stable; the DETAIL failing-row dump is not.
\set VERBOSITY terse
SAVEPOINT sp_t8;
\set ON_ERROR_STOP off
UPDATE public.upgrade SET state = 'failed', error = 'deterministic failure' WHERE id = 1;
ERROR:  new row for relation "upgrade" violates check constraint "chk_upgrade_parked_requires_in_progress"
\set ON_ERROR_STOP on
ROLLBACK TO SAVEPOINT sp_t8;
\set VERBOSITY default
-- The row is untouched: still in_progress and parked.
SELECT id, state, recovery_parked_at IS NOT NULL AS parked FROM public.upgrade ORDER BY id;
 id |    state    | parked 
----+-------------+--------
  1 | in_progress | t
(1 row)

\echo '=== T9: instrumentation trigger logs exactly one row per state/parked change ==='
=== T9: instrumentation trigger logs exactly one row per state/parked change ===
TRUNCATE public.upgrade RESTART IDENTITY;
-- Earlier tests (T4/T5) drive state-changing UPDATEs that this same trigger logs;
-- start T9 from an empty log so the counts below are exact.
TRUNCATE public.upgrade_state_log RESTART IDENTITY;
-- A scheduled row. INSERT is not an UPDATE, so the AFTER UPDATE trigger stays silent.
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, scheduled_at)
VALUES (lpad(to_hex(100), 40, '0'), now(), 'commit', 'scheduled',
        'to be claimed', now());
-- (1) claim: scheduled → in_progress. State changes → one log row (parked f→f).
UPDATE public.upgrade SET state = 'in_progress', started_at = now() WHERE id = 1;
-- (2) park: the guarded park write (parkUpgrade's shape). Parked f→t, state
-- unchanged. recovery_parked_at changes → one log row.
UPDATE public.upgrade SET recovery_parked_at = now(), recovery_parked_reason = 'budget exhausted'
 WHERE id = 1 AND state = 'in_progress' AND recovery_parked_at IS NULL;
-- (3) a non-state, non-parked UPDATE: touches summary only. WHEN clause is false
-- → the trigger does NOT fire, so NO log row is added.
UPDATE public.upgrade SET summary = 'touched, not logged' WHERE id = 1;
-- Exactly two log rows (from steps 1 and 2), in order, with the transitions.
SELECT upgrade_id,
       old_state, new_state,
       (old_parked_at IS NOT NULL) AS was_parked,
       (new_parked_at IS NOT NULL) AS now_parked
  FROM public.upgrade_state_log ORDER BY id;
 upgrade_id |  old_state  |  new_state  | was_parked | now_parked 
------------+-------------+-------------+------------+------------
          1 | scheduled   | in_progress | f          | f
          1 | in_progress | in_progress | f          | t
(2 rows)

SELECT count(*) AS log_row_count FROM public.upgrade_state_log;
 log_row_count 
---------------
             2
(1 row)

\echo '=== T10: superseded → completed is REJECTED (STATBUS-160, terminal not resurrectable) ==='
=== T10: superseded → completed is REJECTED (STATBUS-160, terminal not resurrectable) ===
TRUNCATE public.upgrade RESTART IDENTITY;
-- A displaced (superseded) row — the STATBUS-159 outcome of a fix-release claim.
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, superseded_at)
VALUES (lpad(to_hex(50), 40, '0'), now(), 'commit', 'superseded',
        'displaced by a fix-release claim', now());
-- Promoting it back to completed is exactly the STATBUS-160 lie. The BEFORE UPDATE
-- trigger fires before any constraint check and raises the named-remedy error — so
-- the target's chk_upgrade_state_attributes columns (log path etc.) need not be set.
-- VERBOSITY terse: the ERROR line is deterministic; DETAIL/context are not. SAVEPOINT
-- + ON_ERROR_STOP off are the expected-error gate's WANTED-context markers.
\set VERBOSITY terse
SAVEPOINT sp_t10;
\set ON_ERROR_STOP off
-- expected to fail: upgrade_block_terminal_resurrection rejects terminal→completed
UPDATE public.upgrade SET state = 'completed', completed_at = now() WHERE id = 1;
ERROR:  upgrade row 1 (state=superseded) cannot be completed: terminal rows are not resurrectable — re-dispatch via ./sb upgrade schedule to run it through the pipeline (it completes honestly only if health passes)
\set ON_ERROR_STOP on
ROLLBACK TO SAVEPOINT sp_t10;
\set VERBOSITY default
-- The row is untouched: still superseded.
SELECT id, state, superseded_at IS NOT NULL AS has_superseded_at FROM public.upgrade ORDER BY id;
 id |   state    | has_superseded_at 
----+------------+-------------------
  1 | superseded | t
(1 row)

\echo '=== T11: available → completed is ALLOWED (STATBUS-160, never-attempted install bookkeeping) ==='
=== T11: available → completed is ALLOWED (STATBUS-160, never-attempted install bookkeeping) ===
TRUNCATE public.upgrade RESTART IDENTITY;
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary)
VALUES (lpad(to_hex(50), 40, '0'), now(), 'commit', 'available',
        'never attempted; install-record completes it');
-- OLD.state='available' is NOT in the terminal set → the resurrection trigger's WHEN
-- is false → the completion proceeds, satisfying chk_upgrade_state_attributes for
-- completed (completed_at + log_relative_file_path NOT NULL).
UPDATE public.upgrade SET state = 'completed', completed_at = now(), log_relative_file_path = 'log.txt' WHERE id = 1;
SELECT id, state, completed_at IS NOT NULL AS has_completed_at FROM public.upgrade ORDER BY id;
 id |   state   | has_completed_at 
----+-----------+------------------
  1 | completed | t
(1 row)

\echo '=== T12: superseded → scheduled is ALLOWED (STATBUS-160, deliberate re-dispatch) ==='
=== T12: superseded → scheduled is ALLOWED (STATBUS-160, deliberate re-dispatch) ===
TRUNCATE public.upgrade RESTART IDENTITY;
INSERT INTO public.upgrade (commit_sha, committed_at, release_status, state, summary, superseded_at)
VALUES (lpad(to_hex(50), 40, '0'), now(), 'commit', 'superseded',
        'displaced, will be re-dispatched', now());
-- Re-dispatch (RunSchedule's atomic reset shape) is terminal→scheduled, which the
-- resurrection trigger does NOT block (its WHEN gates only NEW.state='completed').
UPDATE public.upgrade
   SET state = 'scheduled', scheduled_at = now(),
       superseded_at = NULL, started_at = NULL, completed_at = NULL,
       rolled_back_at = NULL, error = NULL
 WHERE id = 1;
NOTICE:  upgrade_notify_daemon: commit_sha=0000000000000000000000000000000000000032
SELECT id, state, scheduled_at IS NOT NULL AS has_scheduled_at, superseded_at IS NOT NULL AS still_superseded FROM public.upgrade ORDER BY id;
 id |   state   | has_scheduled_at | still_superseded 
----+-----------+------------------+------------------
  1 | scheduled | t                | f
(1 row)

\echo '=== all trigger + backstop tests done ==='
=== all trigger + backstop tests done ===
ROLLBACK;
