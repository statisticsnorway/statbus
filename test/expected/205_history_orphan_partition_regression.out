SET datestyle TO 'ISO, DMY';
BEGIN;
\i test/setup.sql
\echo -- test/setup.sql output suppressed for cleaner test output
-- test/setup.sql output suppressed for cleaner test output
\set ECHO none
\echo -- test/setup.sql done, test output follows
-- test/setup.sql done, test output follows
\echo "Regression #102/#105: orphan hash_partition rows must be cleaned up during full rebuild."
"Regression #102/#105: orphan hash_partition rows must be cleaned up during full rebuild."
\echo "derive_statistical_history full-refresh only spawns children for currently-populated"
"derive_statistical_history full-refresh only spawns children for currently-populated"
\echo "partitions. Orphan rows from prior runs survive and inflate the NULL summary via reduce."
"partitions. Orphan rows from prior runs survive and inflate the NULL summary via reduce."
CALL test.set_user_from_email('test.admin@statbus.org');
\i samples/norway/getting-started.sql
\i samples/norway/settings.sql
INSERT INTO settings(activity_category_standard_id,country_id,region_version_id)
SELECT (SELECT id FROM activity_category_standard WHERE code = 'nace_v2.1')
     , (SELECT id FROM public.country WHERE iso_2 = 'NO')
     , (SELECT id FROM public.region_version WHERE code = 'initial')
ON CONFLICT (only_one_setting)
DO UPDATE SET
   activity_category_standard_id = EXCLUDED.activity_category_standard_id,
   country_id = EXCLUDED.country_id,
   region_version_id = EXCLUDED.region_version_id
   WHERE settings.only_one_setting = EXCLUDED.only_one_setting;
;
\i samples/norway/activity_category/activity_category_norway.sql
\copy public.activity_category_enabled_custom FROM 'samples/norway/activity_category/activity_category_norway.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
\i samples/norway/regions/norway-regions-2024.sql
\copy public.region_upload(path, name) FROM 'samples/norway/regions/norway-regions-2024.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
\i samples/norway/sector/sector_norway.sql
\copy public.sector_custom_only FROM 'samples/norway/sector/sector_norway.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
\i samples/norway/legal_form/legal_form_norway.sql
\copy public.legal_form_custom_only FROM 'samples/norway/legal_form/legal_form_norway.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
\i samples/norway/data_source/data_source_norway.sql
\copy public.data_source_custom (code, name) FROM 'samples/norway/data_source/data_source_norway.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
-- === FIXTURE: Two LUs in distinct hash partitions (reuse 204 data files) ===
INSERT INTO public.import_job (definition_id, slug, description, note, edit_comment)
SELECT
    (SELECT id FROM public.import_definition WHERE slug = 'legal_unit_source_dates'),
    'import_205_lu_a',
    'LU A for orphan-partition regression',
    'test/data/204_regression_lu_a.csv',
    '205_history_orphan_partition_regression.sql';
\copy public.import_205_lu_a_upload(valid_from,valid_to,tax_ident,name,birth_date,death_date,physical_address_part1,physical_postcode,physical_postplace,physical_region_code,physical_country_iso_2,postal_address_part1,postal_postcode,postal_postplace,postal_region_code,postal_country_iso_2,primary_activity_category_code,secondary_activity_category_code,sector_code,legal_form_code) FROM 'test/data/204_regression_lu_a.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
CALL worker.process_tasks(p_queue => 'import');
INSERT INTO public.import_job (definition_id, slug, description, note, edit_comment)
SELECT
    (SELECT id FROM public.import_definition WHERE slug = 'legal_unit_source_dates'),
    'import_205_lu_b',
    'LU B for orphan-partition regression',
    'test/data/204_regression_lu_b.csv',
    '205_history_orphan_partition_regression.sql';
\copy public.import_205_lu_b_upload(valid_from,valid_to,tax_ident,name,birth_date,death_date,physical_address_part1,physical_postcode,physical_postplace,physical_region_code,physical_country_iso_2,postal_address_part1,postal_postcode,postal_postplace,postal_region_code,postal_country_iso_2,primary_activity_category_code,secondary_activity_category_code,sector_code,legal_form_code) FROM 'test/data/204_regression_lu_b.csv' WITH (FORMAT csv, DELIMITER ',', QUOTE '"', HEADER true);
CALL worker.process_tasks(p_queue => 'import');
CALL worker.process_tasks(p_queue => 'analytics');
-- === Baseline: verify clean state before orphan injection ===
\echo "--- Baseline: NULL summary must equal partition sums (clean state) ---"
"--- Baseline: NULL summary must equal partition sums (clean state) ---"
SET LOCAL ROLE postgres;
SELECT
    a.unit_type,
    a.aggregate_exists_count,
    COALESCE(p.partitions_sum, 0) AS per_partition_sum,
    a.aggregate_exists_count = COALESCE(p.partitions_sum, 0) AS consistent
FROM (
    SELECT unit_type, exists_count AS aggregate_exists_count
    FROM public.statistical_history
    WHERE resolution = 'year' AND year = 2021 AND hash_partition IS NULL
      AND unit_type IN ('enterprise', 'legal_unit')
) AS a
LEFT JOIN (
    SELECT unit_type, SUM(exists_count)::integer AS partitions_sum
    FROM public.statistical_history
    WHERE resolution = 'year' AND year = 2021 AND hash_partition IS NOT NULL
      AND unit_type IN ('enterprise', 'legal_unit')
    GROUP BY unit_type
) AS p USING (unit_type)
ORDER BY a.unit_type;
 unit_type  | aggregate_exists_count | per_partition_sum | consistent 
------------+------------------------+-------------------+------------
 legal_unit |                      2 |                 2 | t
 enterprise |                      2 |                 2 | t
(2 rows)

RESET ROLE;
CALL test.set_user_from_email('test.admin@statbus.org');
-- === Capture lu_a's legal_unit.id before deletion ===
-- We need the id to (a) perform the DELETE, (b) compute the expected hash_slot
-- post-deletion for the structural assertion. psql \gset captures the column
-- as a ':' variable interpolated into later statements.
SET LOCAL ROLE postgres;
SELECT lu.id AS lu_a_id,
       public.hash_slot('legal_unit'::public.statistical_unit_type, lu.id) AS lu_a_slot
  FROM public.legal_unit AS lu
  JOIN public.external_ident AS ei ON ei.legal_unit_id = lu.id
  JOIN public.external_ident_type AS eit ON eit.id = ei.type_id
 WHERE eit.code = 'tax_ident'
   AND ei.ident = '100000001'  -- tax_ident of 204_regression_lu_a.csv
\gset
RESET ROLE;
CALL test.set_user_from_email('test.admin@statbus.org');
\echo "--- Captured lu_a.id and its computed hash_slot (will be the orphan slot after DELETE) ---"
"--- Captured lu_a.id and its computed hash_slot (will be the orphan slot after DELETE) ---"
\echo :lu_a_id
1
\echo :lu_a_slot
2955
-- === Natural orphan trigger: user-driven DELETE of one legal_unit ===
-- log_base_change fires → base_change_log captures lu_a.id.
-- derive_statistical_unit (scoped branch) orphan-cleanup DELETEs lu_a from
-- statistical_unit + timeline + timepoints + timesegments.
-- Under HEAD code: lu_a's hash_slot is NOT marked dirty (it's absent from
-- _batches, which reads from base tables where lu_a no longer exists), so
-- derive_statistical_{history, unit_facet, history_facet} never visit that
-- slot. Stale rows survive in all three carriers.
SET LOCAL ROLE postgres;
SET CONSTRAINTS ALL DEFERRED;
DELETE FROM public.legal_unit WHERE id = :lu_a_id;
RESET ROLE;
CALL test.set_user_from_email('test.admin@statbus.org');
CALL worker.process_tasks(p_queue => 'analytics');
-- === Assert (a) statistical_history NULL-summary == partition SUM == truth ===
-- Catches the original #102 / #97 inflation. On HEAD: NULL summary sums the
-- orphan partition row belonging to deleted lu_a → exists_count=2 when truth=1.
\echo "--- Assert (a): history NULL-summary consistent with partition sums AND matches statistical_unit truth ---"
"--- Assert (a): history NULL-summary consistent with partition sums AND matches statistical_unit truth ---"
SET LOCAL ROLE postgres;
SELECT
    a.unit_type,
    a.aggregate_exists_count,
    COALESCE(p.partitions_sum, 0) AS per_partition_sum,
    (SELECT COUNT(*)::integer
       FROM public.statistical_unit AS su
      WHERE su.unit_type = a.unit_type
        AND su.valid_from <= '2021-01-01'::date
        AND '2021-01-01'::date < su.valid_until) AS truth,
    a.aggregate_exists_count = COALESCE(p.partitions_sum, 0)
      AND a.aggregate_exists_count = (SELECT COUNT(*)::integer
            FROM public.statistical_unit AS su
           WHERE su.unit_type = a.unit_type
             AND su.valid_from <= '2021-01-01'::date
             AND '2021-01-01'::date < su.valid_until) AS consistent_and_truthful
FROM (
    SELECT unit_type, exists_count AS aggregate_exists_count
    FROM public.statistical_history
    WHERE resolution = 'year' AND year = 2021 AND hash_partition IS NULL
      AND unit_type IN ('enterprise', 'legal_unit')
) AS a
LEFT JOIN (
    SELECT unit_type, SUM(exists_count)::integer AS partitions_sum
    FROM public.statistical_history
    WHERE resolution = 'year' AND year = 2021 AND hash_partition IS NOT NULL
      AND unit_type IN ('enterprise', 'legal_unit')
    GROUP BY unit_type
) AS p USING (unit_type)
ORDER BY a.unit_type;
 unit_type  | aggregate_exists_count | per_partition_sum | truth | consistent_and_truthful 
------------+------------------------+-------------------+-------+-------------------------
 legal_unit |                      1 |                 1 |     1 | t
 enterprise |                      1 |                 1 |     1 | t
(2 rows)

RESET ROLE;
CALL test.set_user_from_email('test.admin@statbus.org');
-- === Assert (b) statistical_unit_facet current-state matches statistical_unit truth ===
-- Catches #109 (inflation) + #110 (overlap). On HEAD: facet SUM > truth
-- because the deleted unit's slot still contributes via statistical_unit_facet_staging.
\echo "--- Assert (b): statistical_unit_facet current-state equals statistical_unit truth ---"
"--- Assert (b): statistical_unit_facet current-state equals statistical_unit truth ---"
SELECT
    f.unit_type,
    SUM(f.count)::integer AS facet_implied_count,
    (SELECT COUNT(*)::integer
       FROM public.statistical_unit AS su
      WHERE su.unit_type = f.unit_type
        AND su.valid_until = 'infinity'::date) AS truth,
    SUM(f.count)::integer = (SELECT COUNT(*)::integer
       FROM public.statistical_unit AS su
      WHERE su.unit_type = f.unit_type
        AND su.valid_until = 'infinity'::date) AS matches
FROM public.statistical_unit_facet AS f
WHERE f.valid_until = 'infinity'::date
  AND f.unit_type IN ('enterprise', 'legal_unit')
GROUP BY f.unit_type
ORDER BY f.unit_type;
 unit_type  | facet_implied_count | truth | matches 
------------+---------------------+-------+---------
 legal_unit |                   1 |     1 | t
 enterprise |                   1 |     1 | t
(2 rows)

-- === Assert (c) structural — zero orphan rows at deleted slot in every carrier ===
-- The strongest version: after deletion + pipeline, the deleted unit's hash_slot
-- must have ZERO rows in every downstream carrier. On HEAD: nonzero in each.
\echo "--- Assert (c): no orphan rows at deleted lu_a's hash_slot in any carrier ---"
"--- Assert (c): no orphan rows at deleted lu_a's hash_slot in any carrier ---"
SET LOCAL ROLE postgres;
SELECT
    'statistical_history'::text                   AS carrier,
    COUNT(*)::integer                             AS orphan_rows
FROM public.statistical_history AS sh
WHERE sh.hash_partition IS NOT NULL
  AND sh.hash_partition @> :lu_a_slot
  AND sh.unit_type IN ('enterprise', 'legal_unit')
  AND sh.exists_count > 0
UNION ALL
SELECT 'statistical_unit_facet_staging',
       COUNT(*)::integer
FROM public.statistical_unit_facet_staging AS s
WHERE s.hash_slot = :lu_a_slot
UNION ALL
SELECT 'statistical_history_facet_partitions',
       COUNT(*)::integer
FROM public.statistical_history_facet_partitions AS p
WHERE p.hash_slot = :lu_a_slot
ORDER BY carrier;
               carrier                | orphan_rows 
--------------------------------------+-------------
 statistical_history                  |           0
 statistical_history_facet_partitions |           0
 statistical_unit_facet_staging       |           0
(3 rows)

RESET ROLE;
CALL test.set_user_from_email('test.admin@statbus.org');
-- === Assert (c') user-surface drilldown parity ===
-- statistical_history_drilldown reads from statistical_history_facet.
-- Aggregated enterprise count at year=2021 must equal the number of enterprises
-- actually present in statistical_unit at that point. On HEAD: inflated by the
-- orphan's legacy facet contribution.
\echo "--- Assert (c'): statistical_history_facet enterprise year=2021 total equals statistical_unit truth ---"
"--- Assert (c'): statistical_history_facet enterprise year=2021 total equals statistical_unit truth ---"
SELECT
    'enterprise'::text                                         AS unit_type,
    COALESCE(SUM(shf.exists_count), 0)::integer                AS drilldown_count,
    (SELECT COUNT(*)::integer
       FROM public.statistical_unit AS su
      WHERE su.unit_type = 'enterprise'
        AND su.valid_from <= '2021-01-01'::date
        AND '2021-01-01'::date < su.valid_until)               AS truth,
    COALESCE(SUM(shf.exists_count), 0)::integer = (SELECT COUNT(*)::integer
       FROM public.statistical_unit AS su
      WHERE su.unit_type = 'enterprise'
        AND su.valid_from <= '2021-01-01'::date
        AND '2021-01-01'::date < su.valid_until)               AS matches
FROM public.statistical_history_facet AS shf
WHERE shf.resolution = 'year'
  AND shf.year = 2021
  AND shf.unit_type = 'enterprise';
 unit_type  | drilldown_count | truth | matches 
------------+-----------------+-------+---------
 enterprise |               1 |     1 | t
(1 row)

ROLLBACK;
