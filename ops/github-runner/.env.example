# Copy to .env on the box (never commit the real .env — it is gitignored).
#
# RUNNER_TOKEN is needed for the FIRST registration only. Mint a fresh 1-hour
# registration token right before the first `docker compose up`:
#
#   gh api -X POST repos/statisticsnorway/statbus/actions/runners/registration-token --jq .token
#
# Paste it below, bring the runner up once, then it is worthless (expires in 1h,
# and the runner persists its own registration into the runner-state volume). You
# can blank it again after the first successful boot.
RUNNER_TOKEN=

# Optional overrides (defaults live in docker-compose.yml):
# RUNNER_URL=https://github.com/statisticsnorway/statbus
# RUNNER_NAME=niue
# RUNNER_LABELS=niue
