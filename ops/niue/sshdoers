# /etc/sshdoers — statbus niue CI allowlist
# Managed by hand; see tmp/niue-sshdoers in the statbus repo for a copy.
# Generated 2026-04-15.

# Abstract hex-digit runs (needed for the 40-char SHA in pg_regress).
# A '#' in a stored command matches any hex digit at runtime.
match hexdigits

# Log to syslog.
syslog auth

#
# Deploy users — invoked by .github/workflows/deploy-to-<slot>.yaml via raw ssh.
# Command shape: `cd ~/statbus && ./sb upgrade apply-latest`
#
statbus_no: cd ~/statbus && ./sb upgrade apply-latest
statbus_tcc: cd ~/statbus && ./sb upgrade apply-latest
statbus_dev: cd ~/statbus && ./sb upgrade apply-latest
statbus_demo: cd ~/statbus && ./sb upgrade apply-latest
statbus_ma: cd ~/statbus && ./sb upgrade apply-latest
statbus_ug: cd ~/statbus && ./sb upgrade apply-latest
statbus_et: cd ~/statbus && ./sb upgrade apply-latest
statbus_jo: cd ~/statbus && ./sb upgrade apply-latest

#
# Notify-all-clouds — invoked by notify-all-clouds.yaml via appleboy ssh-action.
# Command is the single byte-stable entrypoint line (STATBUS-123): the behavior
# lives in ~/statbus/ops/ci-notify.sh (evolves via git); only the PATH is pinned.
# One entry per user (sshdo requires it); identical command for all eight.
#
statbus_no: ~/statbus/ops/ci-notify.sh
statbus_tcc: ~/statbus/ops/ci-notify.sh
statbus_dev: ~/statbus/ops/ci-notify.sh
statbus_demo: ~/statbus/ops/ci-notify.sh
statbus_ma: ~/statbus/ops/ci-notify.sh
statbus_ug: ~/statbus/ops/ci-notify.sh
statbus_et: ~/statbus/ops/ci-notify.sh
statbus_jo: ~/statbus/ops/ci-notify.sh

#
# pg_regress test runner — invoked by pg_regress.yaml via appleboy ssh-action.
# 40 '#' characters match a 40-char hex SHA at runtime (via `match hexdigits`).
#
statbus_test: cd statbus && git fetch origin && git checkout -- . && git checkout ######################################## && ./dev.sh continous-integration-test
